<Window x:Class="ShellApp.Views.AuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Height="620" Width="520"
        MinHeight="620" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource ShellBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0,0,0,1" CornerRadius="0" CaptionHeight="52" ResizeBorderThickness="8" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding TitleBarText}"
                   VerticalAlignment="Center" Margin="24,0,0,0"
                   Style="{StaticResource SubtitleTextStyle}"
                   Foreground="{DynamicResource PrimaryTextBrush}"
                   IsHitTestVisible="False" />

        <ScrollViewer Grid.Row="1" Margin="24,0,32,12"
                      Padding="0,0,8,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="24" Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="{Binding ProductName}" Style="{StaticResource TitleTextStyle}" FontSize="26" FontWeight="Bold" />
                        <TextBlock Text="{Binding VersionDisplay}" Style="{StaticResource BodyTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,20" />

                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="64" Height="64" Margin="0,0,16,0" Stretch="Uniform" VerticalAlignment="Center">
                                <Canvas Width="128" Height="128">
                                    <Ellipse Width="120" Height="120" Canvas.Left="4" Canvas.Top="4" Fill="#4BC190"/>
                                    <Ellipse Width="96" Height="96" Canvas.Left="16" Canvas.Top="16" Fill="#356CB6" Opacity="0.3"/>

                                    <Path Fill="#F8DC25" Data="M101.6,103.14c-1.71-4-6.22-6.64-11.29-6.64H88.87C87.57,84.8,76.93,82,64,82S40.43,84.8,39.13,96.5H37.69c-5.07,0-9.58,2.66-11.29,6.64L24,108.82a60,60,0,0,0,80,0Z"/>
                                    <Path Fill="#F2BC0F" Data="M64,124.1l1,0V112a1,1,0,0,0-2,0v12.08Z"/>
                                    <Path Fill="#FFFFFF" Data="M76,100a12,12,0,1,0-20.93,8H55l7.51,8.35a2,2,0,0,0,3,0L73,108h0A11.89,11.89,0,0,0,76,100Z"/>
                                    <Line X1="64" Y1="84.75" X2="64" Y2="98.5" Stroke="#FBC0AA" StrokeThickness="20" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                    <Ellipse Width="15.86" Height="15.86" Canvas.Left="83.39" Canvas.Top="52.5" Fill="#FBC0AA"/>
                                    <Ellipse Width="15.86" Height="15.86" Canvas.Left="28.75" Canvas.Top="52.5" Fill="#FBC0AA"/>
                                    <Path Fill="#FFD8C9" Data="M64,96C52.47,96,39.88,86.07,36.4,66.2c-3.27-18.66-1-23.74-1-23.74,0-16.41,57.32-16.41,57.32,0,0,0,1.22,7.16-1,23.74C89.19,84,75.55,96,64,96Z"/>
                                    <Path Fill="#515570" Opacity="0.2" Data="M73.17,88.08H54.83c0-1.6-1.08-8.44.17-11.22,2.71-6,9-8.69,9-8.69s6.65,2.53,9.32,8.69C74.41,79.35,73.17,86.62,73.17,88.08Z"/>
                                    <Path Fill="#F85565" Opacity="0.4" Data="M64,81c5,0,7-3,7-3H57S59,81,64,81Z"/>
                                    <Path Fill="#7F3838" Data="M75,78c-.07-5-6-5.08-11-5.08S53.08,73,53,78h0V94.16a28.48,28.48,0,0,0,22,0V78Zm-5,9H67.78a1,1,0,0,1-1-.76l-.62-2.48a1,1,0,0,0-1-.76H62.78a1,1,0,0,0-1,.76l-.62,2.48a1,1,0,0,1-1,.76H58a2,2,0,0,1-2-2V80.08a2,2,0,0,1,2-2H70a2,2,0,0,1,2,2V85A2,2,0,0,1,70,87Z"/>

                                    <Line X1="64" Y1="59.75" X2="64" Y2="72.25" Stroke="#FBC0AA" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="66.5" Y1="71" X2="61.5" Y2="71" Stroke="#FBC0AA" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                    <Rectangle Width="60" Height="15" RadiusX="2" RadiusY="2" Canvas.Left="34" Canvas.Top="31" Fill="#393C54"/>
                                    <Polygon Points="76,25.33 51.61,25.33 40.61,32.33 87,32.33" Fill="#393C54"/>
                                    <Line X1="34" Y1="32" X2="94" Y2="32" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Polygon Points="71,26 57,26 55,19 73,19" Fill="#393C54"/>
                                    <Line X1="53" Y1="19" X2="75" Y2="19" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                    <Path Fill="#393C54" Data="M70.41,56H82.59A2.41,2.41,0,0,1,85,58.41V62a6,6,0,0,1-6,6H74.57A6.57,6.57,0,0,1,68,61.43v-3A2.41,2.41,0,0,1,70.41,56Z"/>
                                    <Path Fill="#393C54" Data="M49.57,56H54a6,6,0,0,1,6,6v3.56A2.41,2.41,0,0,1,57.59,68H45.41A2.41,2.41,0,0,1,43,65.59v-3A6.57,6.57,0,0,1,49.57,56Z"/>
                                    <Path Data="M70.41,56H82.59A2.41,2.41,0,0,1,85,58.41V62a6,6,0,0,1-6,6H74.57A6.57,6.57,0,0,1,68,61.43v-3A2.41,2.41,0,0,1,70.41,56Z"
                                          Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    <Path Data="M49.57,56H54a6,6,0,0,1,6,6v3.56A2.41,2.41,0,0,1,57.59,68H45.41A2.41,2.41,0,0,1,43,65.59v-3A6.57,6.57,0,0,1,49.57,56Z"
                                          Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    <Path Data="M60,62a4,4,0,0,1,8,0" Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="85" Y1="58.41" X2="92.32" Y2="52.5" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="43" Y1="58.41" X2="35.68" Y2="52.57" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                    <Path Fill="#F2BC0F" Data="M37.69,96.5a14.18,14.18,0,0,0-3.08.34S36,106,44,110a19.32,19.32,0,0,1-4.87-13.5Z"/>
                                    <Path Fill="#F2BC0F" Data="M84,110c8-4,9.39-13.16,9.39-13.16a14.18,14.18,0,0,0-3.08-.34H88.87A19.32,19.32,0,0,1,84,110Z"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeveloperName}" Style="{StaticResource SubtitleTextStyle}" />
                                <TextBlock Text="{Binding DeveloperTeam}" Style="{StaticResource BodyTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ReleaseNotesHeading}"
                           Style="{StaticResource SubtitleTextStyle}"
                           Margin="4,0,0,16" />

                <ItemsControl ItemsSource="{Binding ReleaseNotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,16"
                                    Background="{DynamicResource NavBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    CornerRadius="8"
                                    Padding="20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="{Binding VersionTitle}"
                                                   FontWeight="Bold" FontSize="15" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding DateLabel}" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="{Binding Notes}"
                                               Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource PrimaryTextBrush}" LineHeight="22" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="{Binding CloseButtonText}"
                Width="140"
                Height="40"
                Margin="0,0,0,18"
                Style="{DynamicResource PrimaryButtonStyle}"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom" />
    </Grid>
</Window>
