<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:Double x:Key="TitleFontSize">28</sys:Double>
    <sys:Double x:Key="SubtitleFontSize">18</sys:Double>
    <sys:Double x:Key="BodyFontSize">14</sys:Double>
    <sys:Double x:Key="CaptionFontSize">13</sys:Double>
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="PanelRadius">8</CornerRadius>
    <CornerRadius x:Key="CardRadius">10</CornerRadius>

    <DropShadowEffect x:Key="CardShadowLevel1"
                      BlurRadius="14"
                      ShadowDepth="2"
                      Opacity="0.14" />
    <DropShadowEffect x:Key="CardShadowLevel2"
                      BlurRadius="24"
                      ShadowDepth="4"
                      Opacity="0.22" />

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource TitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource SubtitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            CornerRadius="{StaticResource SmallRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Margin="0"
                            Opacity="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ホーム画面のプラグインカード -->
    <Style x:Key="PluginCardButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource NavBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CardBorder"
                            CornerRadius="{StaticResource CardRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5"
                            Effect="{StaticResource CardShadowLevel1}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CardBounceTranslate" Y="0" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource CardShadowLevel2}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardBounceTranslate"
                                                                       Storyboard.TargetProperty="Y">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="-4">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.2">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="-1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.36" Value="0">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBounceTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="CardBorder" Property="Opacity" Value="0.95" />
                            <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource CardShadowLevel1}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            CornerRadius="{StaticResource SmallRadius}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Margin="0"
                            Opacity="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AboutAppStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,14,60,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ToolTip" Value="開発者情報 ＆ アップデート履歴" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="5"
                            Margin="0"
                            Opacity="1"
                            ClipToBounds="False"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Viewbox Width="28"
                                 Height="28"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource AboutIconGeometry}"
                                  Fill="{DynamicResource PrimaryTextBrush}"
                                  Stretch="Uniform" />
                        </Viewbox>
                        <!-- ホバー時の呼吸アニメーション（押下状態と競合しないよう MouseLeave で停止） -->
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Name="AboutBreathingStoryboard">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         From="1"
                                                         To="{StaticResource IconHoverScale}"
                                                         Duration="{StaticResource IconHoverBreathDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         From="1"
                                                         To="{StaticResource IconHoverScale}"
                                                         Duration="{StaticResource IconHoverBreathDuration}">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <StopStoryboard BeginStoryboardName="AboutBreathingStoryboard" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="{StaticResource IconHoverReturnDuration}" />
                                        <DoubleAnimation Storyboard.TargetName="Root"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="{StaticResource IconHoverReturnDuration}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ThemeIconToggleStyle と同様：40×40 のヒット領域。SVG ベクター＋ホバー時ワイヤのストローク描画アニメ -->
    <sys:Double x:Key="ShutdownWireDashLength">96</sys:Double>
    <Style x:Key="ExitAppStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,14,14,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ToolTip" Value="閉じる" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="5"
                            Margin="0"
                            Opacity="1">
                        <Viewbox Width="26"
                                 Height="26"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 SnapsToDevicePixels="True">
                            <Grid Width="24"
                                  Height="24">
                                <!-- 通常：塗りつぶしアイコン（元 SVG） -->
                                <Canvas x:Name="ShutdownNormal"
                                        Width="24"
                                        Height="24"
                                        Visibility="Visible">
                                    <Path Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5">
                                        <Path.Data>
                                            <PathGeometry FillRule="EvenOdd"
                                                          Figures="M12.7497,22 C17.9224,21.6161 22,17.2918 22,12.0139 L22,12.0069 L22,12 C22,6.47715 17.5228,2 12,2 C6.47715,2 2,6.47715 2,12 L2,12.0069 L2,12.0139 C2,17.2918 6.07759,21.6161 11.2503,22 L11.2503,21.9723 C6.07986,21.5891 2.00357,17.2744 2,12.0069 C2.00374,6.47961 6.47946,2 12,2 C17.5205,2 21.9963,6.47961 22,12.0069 C21.9964,17.2744 17.9201,21.5891 12.7497,21.9723 L12.7497,22 Z" />
                                        </Path.Data>
                                    </Path>
                                    <Path Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5"
                                          Data="M11.2503,21.9723 C11.4978,21.9907 11.7478,22 12,22 C12.2522,22 12.5022,21.9907 12.7497,21.9723 C17.9201,21.5891 21.9964,17.2744 22,12.0069 C21.9963,6.47961 17.5205,2 12,2 C6.47946,2 2.00374,6.47961 2,12.0069 C2.00357,17.2744 6.07986,21.5891 11.2503,21.9723 Z" />
                                    <Path Fill="{DynamicResource PrimaryTextBrush}"
                                          Data="M8.5,12.5147 C8.5,14.1925 9.67737,15.595 11.2499,15.9389 L11.2503,21.9724 C11.4978,21.9908 11.7478,22.0001 12,22.0001 C12.2522,22.0001 12.5022,21.9908 12.7497,21.9724 L12.7499,15.9389 C14.3226,15.5951 15.5,14.1926 15.5,12.5147 L15.5,12.014 C15.5,11.4609 15.0523,11.0126 14.5,11.0126 L14.25,11.0126 L14.25,9.00983 C14.25,8.59504 13.9142,8.25879 13.5,8.25879 C13.0858,8.25879 12.75,8.59504 12.75,9.00983 L12.75,11.0126 L11.25,11.0126 L11.25,9.00983 C11.25,8.59504 10.9142,8.25879 10.5,8.25879 C10.0858,8.25879 9.75,8.59504 9.75,9.00983 L9.75,11.0126 L9.5,11.0126 C8.94772,11.0126 8.5,11.4609 8.5,12.014 L8.5,12.5147 Z" />
                                </Canvas>
                                <!-- ホバー：輪郭線＋コードをストロークで徐々に表示（プラグ付近から末端へ） -->
                                <Canvas x:Name="ShutdownHover"
                                        Width="24"
                                        Height="24"
                                        Visibility="Collapsed">
                                    <Path x:Name="ShutdownWireStroke"
                                          Stroke="{DynamicResource PrimaryTextBrush}"
                                          StrokeThickness="1.7"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"
                                          Opacity="0.55"
                                          StrokeDashCap="Round"
                                          StrokeDashOffset="{StaticResource ShutdownWireDashLength}"
                                          StrokeDashArray="96 96"
                                          Data="M12,15 L12,20.1498 C11.5214,23.0394 10.6697,21.3355 9.86335,22.7023 C4.94577,21.7025 1.25,17.3253 1.25,12.0832 C1.25,6.10606 6.05709,1.25 12,1.25 C17.9429,1.25 22.75,6.10606 22.75,12.0832 C22.75,16.369 20.2798,20.0752 16.6941,21.8316" />
                                    <Path Stroke="{DynamicResource PrimaryTextBrush}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"
                                          Data="M9,11.8 C9,11.3582 9.35817,11 9.8,11 L14.2,11 C14.6418,11 15,11.3582 15,11.8 L15,12 C15,13.6569 13.6569,15 12,15 C10.3431,15 9,13.6569 9,12 L9,11.8 Z" />
                                    <Path Stroke="{DynamicResource PrimaryTextBrush}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M13.5,11 L13.5,9" />
                                    <Path Stroke="{DynamicResource PrimaryTextBrush}"
                                          StrokeThickness="1.5"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M10.5,11 L10.5,9" />
                                </Canvas>
                            </Grid>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                            <Setter TargetName="ShutdownNormal" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ShutdownHover" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShutdownWireStroke"
                                                         Storyboard.TargetProperty="StrokeDashOffset"
                                                         From="{StaticResource ShutdownWireDashLength}"
                                                         To="0"
                                                         Duration="0:0:2.4">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ShutdownWireStroke"
                                                         Storyboard.TargetProperty="StrokeDashOffset"
                                                         To="{StaticResource ShutdownWireDashLength}"
                                                         Duration="0:0:0.45" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGridTextColumn のセル内 TextBlock はアプリの暗黙スタイルが効かないため、ElementStyle 用 -->
    <Style x:Key="DataGridTextColumnElementStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}"
                         Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ToolTip" Value="{Binding Description}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="{StaticResource SmallRadius}"
                            Opacity="1">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Height="16"
                                    Width="3"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource IndicatorBrush}"
                                    CornerRadius="1.5"
                                    Visibility="Collapsed" />
                            <ContentPresenter />
                        </Grid>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
                                <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ItemBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.82"
                                                         Duration="0:0:0.06"
                                                         AutoReverse="True" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- ホバー：グラデーション＋わずかな拡大（単色より視認しやすい） -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavIconStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Margin" Value="22,0,0,0" />
        <Setter Property="Width" Value="32" />
        <Setter Property="TextAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                         Value="True">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavImageStyle" TargetType="Image">
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Margin" Value="22,0,0,0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                         Value="True">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NavTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="FontSize" Value="{StaticResource SubtitleFontSize}" />
        <Setter Property="Margin" Value="70,0,0,0" />
    </Style>

    <Style x:Key="SecondaryTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- 太陽／月（SVG ベクター）。ライト＝太陽、ダーク＝月（IsChecked はダークテーマ） -->
    <Style x:Key="ThemeIconToggleStyle" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ToolTip" Value="ライト／ダークテーマの切り替え" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="6"
                            Margin="0"
                            Opacity="1">
                        <Viewbox Width="22" Height="22" Stretch="Uniform"
                                 RenderTransformOrigin="0.5,0.5">
                            <Grid Width="24" Height="24"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="ThemeIconRotate" Angle="0" />
                                        <ScaleTransform x:Name="ThemeIconScale" ScaleX="1" ScaleY="1" />
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <!-- ライトモード用の太陽（IsChecked = False） -->
                                <Canvas x:Name="SunIcon" Visibility="Visible">
                                    <Path Data="{StaticResource ThemeSunCenterGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                    <Path Data="{StaticResource ThemeSunRaysGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                    <Path Data="{StaticResource ThemeSunCorner1Geometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5" />
                                    <Path Data="{StaticResource ThemeSunCorner2Geometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5" />
                                    <Path Data="{StaticResource ThemeSunCorner3Geometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5" />
                                    <Path Data="{StaticResource ThemeSunCorner4Geometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5" />
                                </Canvas>
                                <!-- ダークモード用の月（IsChecked = True） -->
                                <Canvas x:Name="MoonIcon" Visibility="Collapsed">
                                    <Path Data="{StaticResource ThemeMoonSparkleLargeGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                    <Path Data="{StaticResource ThemeMoonSparkleSmallGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                    <Path Data="{StaticResource ThemeMoonBodyGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}"
                                          Opacity="0.5" />
                                </Canvas>
                            </Grid>
                        </Viewbox>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- ダーク時は月（ホバーしない） -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SunIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MoonIcon" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- ホバー：ライト→月へプレビュー（太陽が月へ反転） -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SunIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MoonIcon" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                        <!-- ホバー：ダーク→太陽へプレビュー（月が太陽へ反転） -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SunIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MoonIcon" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 現在角度から 360° へ（From 省略で途中離脱後も連続しやすい） -->
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="360"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1.1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1.1"
                                                         Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 現在の角度から 0 へ戻す＝進入時と逆向きの回転 -->
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="0"
                                                         Duration="0:0:0.42">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ThemeIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1"
                                                         Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ThemeIconToggleStyle と見た目を揃えるための「ボタン版」。刷新ボタン用に使う -->
    <Style x:Key="ThemeIconActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="6"
                            Margin="0"
                            Opacity="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid：選択時にテーマの HighlightText（白）が当たり、ライトテーマで文字が見えなくなるのを防ぐ -->
    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- プラグイン等の UserControl は既定でコンテンツ領域の背景色を使用し、Transparent による下層の既定の白の透けを防ぐ -->
    <Style TargetType="UserControl">
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="40" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Visibility" Value="Collapsed">
                <Setter Property="Opacity" Value="0" />
            </Trigger>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         Duration="0:0:0.5"
                                         From="0"
                                         To="1" />
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                         From="40"
                                         To="0"
                                         Duration="0:0:0.35"
                                         DecelerationRatio="0.6" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
