<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
                    xmlns:svgc="http://sharpvectors.codeplex.com/svgc/">
    <CornerRadius x:Key="SmallRadius">4</CornerRadius>
    <CornerRadius x:Key="PanelRadius">8</CornerRadius>
    <CornerRadius x:Key="CardRadius">10</CornerRadius>

    <DropShadowEffect x:Key="CardShadowLevel1"
                      BlurRadius="14"
                      ShadowDepth="2"
                      Opacity="0.14" />
    <DropShadowEffect x:Key="CardShadowLevel2"
                      BlurRadius="24"
                      ShadowDepth="4"
                      Opacity="0.22" />

    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.TitleFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.SubtitleFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.CaptionFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>

    <!-- ステータス行・キュー状態など、本文サイズで強調したい一行 -->
    <Style x:Key="KeyInfoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.ButtonFontSize}" />
        <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            CornerRadius="{StaticResource SmallRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Margin="0"
                            Opacity="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ホーム画面のプラグインカード -->
    <Style x:Key="PluginCardButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.ButtonFontSize}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource NavBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CardBorder"
                            CornerRadius="{StaticResource CardRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            RenderTransformOrigin="0.5,0.5"
                            Effect="{StaticResource CardShadowLevel1}">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="CardBounceTranslate" Y="0" />
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource CardShadowLevel2}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CardBounceTranslate"
                                                                       Storyboard.TargetProperty="Y">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="-4">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.2">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="-1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.36" Value="0">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBounceTranslate"
                                                         Storyboard.TargetProperty="Y"
                                                         To="0"
                                                         Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="CardBorder" Property="Opacity" Value="0.95" />
                            <Setter TargetName="CardBorder" Property="Effect" Value="{StaticResource CardShadowLevel1}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.ButtonFontSize}" />
        <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            CornerRadius="{StaticResource SmallRadius}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            Margin="0"
                            Opacity="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.3" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- プレビュー左右切替：選択側を Primary 系に。BasedOn は StaticResource のみ（プラグイン XAML で DynamicResource BasedOn は解析エラーになりやすい） -->
    <Style x:Key="PreviewLeftToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding ShowLeftPreview}" Value="True">
                <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
                <Setter Property="BorderThickness" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="PreviewRightToggleButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
        <Style.Triggers>
            <DataTrigger Binding="{Binding ShowLeftPreview}" Value="False">
                <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
                <Setter Property="BorderThickness" Value="0" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AboutAppStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ToolTip" Value="開発者情報 ＆ アップデート履歴" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="2"
                            Margin="0"
                            Opacity="1"
                            ClipToBounds="False"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="AboutRootScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- 発光リング（ホバー時にパルス表示） -->
                            <Ellipse x:Name="GlowRing"
                                     Width="36" Height="36"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     StrokeThickness="2"
                                     Opacity="0"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF42A5F5" Offset="0" />
                                        <GradientStop Color="#FFAB47BC" Offset="0.5" />
                                        <GradientStop Color="#FF26C6DA" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Stroke>
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="GlowRingRotate" Angle="0" />
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- アイコン本体 -->
                            <Viewbox Width="24" Height="24"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Viewbox.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="AboutIconSpin" Angle="0" />
                                        <ScaleTransform x:Name="AboutIconPulse" ScaleX="1" ScaleY="1" />
                                    </TransformGroup>
                                </Viewbox.RenderTransform>
                                <Grid Width="24" Height="24">
                                    <!-- 通常：filled SVG -->
                                    <svgc:SvgViewbox x:Name="AboutIconFullHost"
                                                     Source="/Assets/SVG/user-person-profile-block-account-circle-full.svg"
                                                     Stretch="Uniform"
                                                     Width="24"
                                                     Height="24"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Visibility="Visible" />
                                    <!-- ホバー：empty SVG -->
                                    <svgc:SvgViewbox x:Name="AboutIconEmptyHost"
                                                     Source="/Assets/SVG/user-person-profile-block-account-circle-emptysvg.svg"
                                                     Stretch="Uniform"
                                                     Width="24"
                                                     Height="24"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Visibility="Collapsed" />
                                </Grid>
                            </Viewbox>
                        </Grid>
                        <Border.Triggers>
                            <!-- ホバー：アイコン回転＋パルス＋発光リング -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard x:Name="AboutHoverStoryboard">
                                    <Storyboard>
                                        <!-- アイコン 360° 回転 -->
                                        <DoubleAnimation Storyboard.TargetName="AboutIconSpin"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:1.8"
                                                         RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- アイコン拡縮パルス -->
                                        <DoubleAnimation Storyboard.TargetName="AboutIconPulse"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="1" To="1.15"
                                                         Duration="0:0:0.6"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AboutIconPulse"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="1" To="1.15"
                                                         Duration="0:0:0.6"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 発光リング：フェードイン -->
                                        <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.8"
                                                         Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <!-- 発光リング：回転（アイコンと逆方向） -->
                                        <DoubleAnimation Storyboard.TargetName="GlowRingRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="-360"
                                                         Duration="0:0:3"
                                                         RepeatBehavior="Forever" />
                                        <!-- 発光リング：呼吸パルス -->
                                        <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                         Storyboard.TargetProperty="StrokeThickness"
                                                         From="1.5" To="3"
                                                         Duration="0:0:0.8"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <StopStoryboard BeginStoryboardName="AboutHoverStoryboard" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AboutIconSpin"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="0" Duration="0:0:0.3">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AboutIconPulse"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="AboutIconPulse"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="GlowRingRotate"
                                                         Storyboard.TargetProperty="Angle"
                                                         To="0" Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="AboutIconFullHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="AboutIconEmptyHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- 按下：弹性缩小 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonPressedGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AboutRootScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.85" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="AboutRootScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.85" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AboutRootScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="AboutRootScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="1.1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1">
                                                <EasingDoubleKeyFrame.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut" />
                                                </EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 閉じるボタン：switch-on/off SVG を ToggleButton で切替。ホバー時スケール呼吸アニメ、クリックで off に切り替わり閉じる -->
    <Style x:Key="ExitAppToggleStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ToolTip" Value="閉じる" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Root"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="{StaticResource SmallRadius}"
                            Padding="3"
                            Margin="0"
                            Opacity="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ExitScale" ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Grid>
                            <!-- ON 状態（通常表示） -->
                            <svgc:SvgViewbox x:Name="SwitchOnIcon"
                                             Source="/Assets/SVG/switch-on-svgrepo-com.svg"
                                             Stretch="Uniform"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Visible" />
                            <!-- OFF 状態（クリック後表示） -->
                            <svgc:SvgViewbox x:Name="SwitchOffIcon"
                                             Source="/Assets/SVG/switch-off-svgrepo-com.svg"
                                             Stretch="Uniform"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Visibility="Collapsed" />
                        </Grid>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard x:Name="ExitHoverBreathStoryboard">
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="ExitScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="1" To="1.12"
                                                         Duration="0:0:0.7">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ExitScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="1" To="1.12"
                                                         Duration="0:0:0.7">
                                            <DoubleAnimation.EasingFunction>
                                                <SineEase EasingMode="EaseInOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <StopStoryboard BeginStoryboardName="ExitHoverBreathStoryboard" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ExitScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="ExitScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="Root" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <!-- IsChecked = True → OFF 状態 -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchOnIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SwitchOffIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.75" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGridTextColumn のセル内 TextBlock はアプリの暗黙スタイルが効かないため、ElementStyle 用 -->
    <Style x:Key="DataGridTextColumnElementStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}"
                         Value="True">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AppDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.DataGridHeaderFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style x:Key="NavListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="NavListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="8,2,8,2" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="ToolTip" Value="{Binding Description}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Height="40"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            CornerRadius="{StaticResource SmallRadius}"
                            Opacity="1">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Height="16"
                                    Width="3"
                                    Margin="1,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource IndicatorBrush}"
                                    CornerRadius="1.5"
                                    Visibility="Collapsed" />
                            <ContentPresenter />
                        </Grid>
                        <Border.Triggers>
                            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
                                <BeginStoryboard HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ItemBorder"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.82"
                                                         Duration="0:0:0.06"
                                                         AutoReverse="True" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Border.Triggers>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- ホバー：グラデーション＋わずかな拡大（単色より視認しやすい） -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- テーブル風 ListBox 行：Theme の ListItemHoverBrush / ListItemSelectedBrush（ComboBox 候補と同じトーン） -->
    <Style x:Key="AppFlatSelectableRowListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
