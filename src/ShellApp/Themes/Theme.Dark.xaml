<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#00000000</Color>
    <Color x:Key="ShellBackgroundColor">#202020</Color>
    <Color x:Key="NavBackgroundColor">#202020</Color>
    <Color x:Key="HoverColor">#333333</Color>
    <Color x:Key="SelectedColor">#282828</Color>
    <Color x:Key="IndicatorColor">#60CDFF</Color>
    <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
    <Color x:Key="SecondaryTextColor">#999999</Color>
    <Color x:Key="ContentBackgroundColor">#282828</Color>
    <Color x:Key="SwitchOnColor">#60CDFF</Color>
    <Color x:Key="SwitchOffColor">#333333</Color>
    <Color x:Key="SwitchThumbColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="{StaticResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <SolidColorBrush x:Key="IndicatorBrush" Color="{StaticResource IndicatorColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}" />
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#000000" />
    <SolidColorBrush x:Key="SwitchOnBrush" Color="{StaticResource SwitchOnColor}" />
    <SolidColorBrush x:Key="SwitchOffBrush" Color="{StaticResource SwitchOffColor}" />
    <SolidColorBrush x:Key="SwitchThumbBrush" Color="{StaticResource SwitchThumbColor}" />

    <SolidColorBrush x:Key="ButtonHoverGradientBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="ButtonPressedGradientBrush" Color="#252525" />
</ResourceDictionary>
