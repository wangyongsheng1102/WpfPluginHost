<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 本文・コントロール既定：Light。見出し・列見出し等は AppFontFamilyBold。両方 Assets/Fonts に配置（LXGW リリースの Light / Bold）。ファミリー名は「LXGW WenKai」。絵文字は Segoe UI Emoji にフォールバック -->
    <FontFamily x:Key="AppFontFamily">pack://application:,,,/Assets/Fonts/LXGWWenKai-Light.ttf#LXGW WenKai, Segoe UI Emoji</FontFamily>
    <FontFamily x:Key="AppFontFamilyBold">pack://application:,,,/Assets/Fonts/LXGWWenKai-Bold.ttf#LXGW WenKai, Segoe UI Emoji</FontFamily>

    <Style TargetType="Window">
        <Setter Property="TextElement.FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

    <Style TargetType="Control">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>
</ResourceDictionary>
