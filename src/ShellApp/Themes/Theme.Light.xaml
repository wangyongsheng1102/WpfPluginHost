<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#00000000</Color>
    <Color x:Key="ShellBackgroundColor">#F3F3F3</Color>
    <Color x:Key="NavBackgroundColor">#F3F3F3</Color>
    <Color x:Key="HoverColor">#E0E0E0</Color>
    <!-- ナビ等の汎用選択（白すぎない程度） -->
    <Color x:Key="SelectedColor">#C5E0F7</Color>
    <Color x:Key="IndicatorColor">#005FB8</Color>
    <Color x:Key="PrimaryTextColor">#E4000000</Color>
    <Color x:Key="SecondaryTextColor">#99000000</Color>
    <Color x:Key="ContentBackgroundColor">#FFFFFF</Color>
    <Color x:Key="BorderSubtleColor">#D5D9DE</Color>
    <Color x:Key="CardElevatedColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#2E8B57</Color>
    <Color x:Key="WarningColor">#B7791F</Color>
    <Color x:Key="ErrorColor">#C53030</Color>
    <Color x:Key="SwitchOnColor">#005FB8</Color>
    <Color x:Key="SwitchOffColor">#CCCCCC</Color>
    <Color x:Key="SwitchThumbColor">#FFFFFF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="ShellBackgroundBrush" Color="{StaticResource ShellBackgroundColor}" />
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="{StaticResource NavBackgroundColor}" />
    <SolidColorBrush x:Key="HoverBrush" Color="{StaticResource HoverColor}" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" />
    <!-- DataGrid 行ホバー／選択：明暗どちらでも判別できるようコントラストを確保 -->
    <SolidColorBrush x:Key="DataGridRowHoverBrush" Color="#EAF3FF" />
    <SolidColorBrush x:Key="DataGridRowSelectedBrush" Color="#3D8FD6" />
    <SolidColorBrush x:Key="DataGridRowSelectedBorderBrush" Color="#1E6FB5" />
    <SolidColorBrush x:Key="DataGridRowSelectedTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="IndicatorBrush" Color="{StaticResource IndicatorColor}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="{StaticResource ContentBackgroundColor}" />
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="CardElevatedBrush" Color="{StaticResource CardElevatedColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="PrimaryButtonTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SwitchOnBrush" Color="{StaticResource SwitchOnColor}" />
    <SolidColorBrush x:Key="SwitchOffBrush" Color="{StaticResource SwitchOffColor}" />
    <SolidColorBrush x:Key="SwitchThumbBrush" Color="{StaticResource SwitchThumbColor}" />

    <SolidColorBrush x:Key="ButtonHoverGradientBrush" Color="#F4F4F4" />
    <SolidColorBrush x:Key="ButtonPressedGradientBrush" Color="#EAEAEA" />
</ResourceDictionary>
