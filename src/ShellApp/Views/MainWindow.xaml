<Window x:Class="ShellApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF Plugin Shell"
        Height="600"
        Width="850"
        MinHeight="560"
        MinWidth="820"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <Grid.Resources>
            <ControlTemplate x:Key="InvisibleThumbTemplate" TargetType="Thumb">
                <Border Background="Transparent" />
            </ControlTemplate>
        </Grid.Resources>
        <Border Background="{DynamicResource ShellBackgroundBrush}"
                CornerRadius="8" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="NavPanel"
                  HorizontalAlignment="Left"
                  Width="260">
                <Border Background="{DynamicResource NavBackgroundBrush}"
                        CornerRadius="8,0,0,8" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Margin="10,10,10,4"
                            Width="42"
                            Height="32"
                            HorizontalAlignment="Left"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ToggleMenuCommand}">
                        <TextBlock Text="☰"
                                   FontSize="16"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Button>

                    <TextBlock Grid.Row="1"
                               Margin="14,0,0,4"
                               Style="{StaticResource SecondaryTextStyle}"
                               Text="{Binding PluginCountText}" />

                    <ListBox Grid.Row="2"
                             Margin="0,4,0,10"
                             Style="{StaticResource NavListBoxStyle}"
                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}"
                             ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid>
                                        <Image Source="{Binding IconImagePath}">
                                            <Image.Style>
                                                <Style TargetType="Image" BasedOn="{StaticResource NavImageStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding IconGlyph}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource NavIconStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NavTextStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="3"
                          Margin="12,0,12,12"
                          HorizontalAlignment="Left">
                        <ToggleButton IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                      Style="{StaticResource ThemeIconToggleStyle}" />
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- 标题栏区域：仅内容列，避免遮挡左侧汉堡菜单；拖拽移动、双击最大化 -->
                <Border Grid.Row="0"
                        Background="Transparent"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown" />
                <!-- 上边距加大：与右上角关闭按钮、标题栏拉开，避免与子页面挤在一起 -->
                <Border Grid.Row="1"
                        Margin="0,14,12,12"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        CornerRadius="8">
                    <!-- 显式背景：避免未设置时透出系统默认浅色块（深色模式下子页发白） -->
                    <ContentControl Margin="8"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    Content="{Binding CurrentView}" />
                </Border>
            </Grid>
        </Grid>

        <Button Style="{StaticResource ExitAppStyle}"
                Click="CloseButton_Click"
                ToolTip="Close" />

        <!-- Edge Resize Thumbs -->
        <Thumb Width="6" Cursor="SizeWE" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0,12,0,12" Background="Transparent" DragDelta="ResizeLeft_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Height="6" Cursor="SizeNS" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="12,0,12,0" Background="Transparent" DragDelta="ResizeTop_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Width="6" Cursor="SizeWE" HorizontalAlignment="Right" VerticalAlignment="Stretch" Margin="0,12,0,12" Background="Transparent" DragDelta="ResizeRight_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Height="6" Cursor="SizeNS" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Margin="12,0,12,0" Background="Transparent" DragDelta="ResizeBottom_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        
        <!-- Corner Resize Thumbs -->
        <Thumb Width="12" Height="12" Cursor="SizeNWSE" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" DragDelta="ResizeTopLeft_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Width="12" Height="12" Cursor="SizeNESW" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" DragDelta="ResizeTopRight_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Width="12" Height="12" Cursor="SizeNESW" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" DragDelta="ResizeBottomLeft_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
        <Thumb Width="12" Height="12" Cursor="SizeNWSE" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" DragDelta="ResizeBottomRight_DragDelta" Template="{StaticResource InvisibleThumbTemplate}"/>
    </Grid>
</Window>
