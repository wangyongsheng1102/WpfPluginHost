<Window x:Class="ShellApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF プラグインシェル"
        Height="600"
        Width="850"
        MinHeight="560"
        MinWidth="820"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0,0,0,1" CornerRadius="0" CaptionHeight="52" ResizeBorderThickness="8" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="NavPanel"
                  HorizontalAlignment="Left"
                  Width="260">
                <Border Background="{DynamicResource NavBackgroundBrush}"
                        CornerRadius="8,0,0,8" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Margin="10,10,10,4"
                            Width="42"
                            Height="32"
                            HorizontalAlignment="Left"
                            Style="{StaticResource ActionButtonStyle}"
                            Command="{Binding ToggleMenuCommand}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="☰"
                                   FontSize="16"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Button>

                    <TextBlock Grid.Row="1"
                               Margin="14,0,0,4"
                               Style="{StaticResource SecondaryTextStyle}"
                               Text="{Binding PluginCountText}" />

                    <ListBox Grid.Row="2"
                             Margin="0,4,0,10"
                             Style="{StaticResource NavListBoxStyle}"
                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}"
                             ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid>
                                        <Image Source="{Binding IconImagePath}">
                                            <Image.Style>
                                                <Style TargetType="Image" BasedOn="{StaticResource NavImageStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding IconGlyph}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource NavIconStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NavTextStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3"
                                Margin="18,0,0,12"
                                Orientation="Vertical"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom">
                        
                        <Button Width="40" Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource ActionButtonStyle}"
                                Command="{Binding ReloadPluginsCommand}"
                                ToolTip="プラグインを再読み込み">
                            <TextBlock Text="🔄"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Button>

                        <ToggleButton IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                      Style="{StaticResource ThemeIconToggleStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- タイトルバー領域 -->
                <Border Grid.Row="0"
                        Background="Transparent" />
                <!-- 上マージン：閉じるボタン・タイトルバーと子ページの間を空ける -->
                <Border Grid.Row="1"
                        Margin="0,14,12,12"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        CornerRadius="8">
                    <!-- 背景を明示：未設定時のシステム既定の明色が透けるのを防ぐ（ダーク時の子ページの白浮き対策） -->
                    <ContentControl Margin="8"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    Content="{Binding CurrentView}" />
                </Border>
            </Grid>
        </Grid>

        <Button Style="{StaticResource ExitAppStyle}"
                Click="CloseButton_Click"
                ToolTip="閉じる"
                WindowChrome.IsHitTestVisibleInChrome="True" />
    </Grid>
</Window>
