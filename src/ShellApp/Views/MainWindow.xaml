    <Window x:Class="ShellApp.Views.MainWindow"
            x:Name="RootWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShellApp.Converters"
        xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF プラグインシェル"
        Height="{x:Static abstractions:ThemeDimensions.MainWindowHeight}"
        Width="{x:Static abstractions:ThemeDimensions.MainWindowWidth}"
        MinHeight="{x:Static abstractions:ThemeDimensions.MainWindowMinHeight}"
        MinWidth="{x:Static abstractions:ThemeDimensions.MainWindowMinWidth}"
        AllowsTransparency="False"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellBackgroundBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0,0,0,1" CornerRadius="0" CaptionHeight="{x:Static abstractions:ThemeDimensions.CaptionBarHeight}" ResizeBorderThickness="8" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="NavPanel"
                  HorizontalAlignment="Left"
                  Width="{x:Static abstractions:ThemeDimensions.NavExpandedWidth}"
                  ClipToBounds="True">
                <Border Background="{DynamicResource NavBackgroundBrush}"
                        CornerRadius="8,0,0,8" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Margin="10,14,10,4"
                            Width="{x:Static abstractions:ThemeDimensions.IconButtonSize}"
                            Height="{x:Static abstractions:ThemeDimensions.IconButtonSize}"
                            HorizontalAlignment="Center"
                            Command="{Binding ToggleMenuCommand}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Padding="0"
                            Style="{StaticResource ThemeIconActionButtonStyle}">
                        <Button.RenderTransform>
                            <TranslateTransform X="4" />
                        </Button.RenderTransform>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard Name="MenuToggleWiggleStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineTopTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         From="-2"
                                                         To="2"
                                                         Duration="0:0:0.18"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever" />
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineMidTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         From="-1"
                                                         To="1"
                                                         Duration="0:0:0.18"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever" />
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineBottomTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         From="-2"
                                                         To="2"
                                                         Duration="0:0:0.18"
                                                         AutoReverse="True"
                                                         RepeatBehavior="Forever" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <StopStoryboard BeginStoryboardName="MenuToggleWiggleStoryboard" />
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineTopTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineMidTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="HamburgerLineBottomTranslate"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                        <Grid Width="{x:Static abstractions:ThemeDimensions.HamburgerGridSize}"
                              Height="{x:Static abstractions:ThemeDimensions.HamburgerGridSize}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>
                            <Rectangle Grid.Row="0"
                                       Width="{x:Static abstractions:ThemeDimensions.HamburgerBarWidth}"
                                       Height="{x:Static abstractions:ThemeDimensions.HamburgerBarHeight}"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="HamburgerLineTopTranslate" X="0" Y="0" />
                                </Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Grid.Row="1"
                                       Width="{x:Static abstractions:ThemeDimensions.HamburgerBarWidth}"
                                       Height="{x:Static abstractions:ThemeDimensions.HamburgerBarHeight}"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="HamburgerLineMidTranslate" X="0" Y="0" />
                                </Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Grid.Row="2"
                                       Width="{x:Static abstractions:ThemeDimensions.HamburgerBarWidth}"
                                       Height="{x:Static abstractions:ThemeDimensions.HamburgerBarHeight}"
                                       RadiusX="1"
                                       RadiusY="1"
                                       Fill="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <Rectangle.RenderTransform>
                                    <TranslateTransform x:Name="HamburgerLineBottomTranslate" X="0" Y="0" />
                                </Rectangle.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Button>

                    <Button Grid.Row="1"
                            Margin="10,0,10,8"
                            Height="{x:Static abstractions:ThemeDimensions.IconButtonSize}"
                            HorizontalAlignment="Stretch"
                            Padding="10,8"
                            ToolTip="ホーム"
                            Command="{Binding ShowHomeCommand}">
                        <Button.RenderTransform>
                            <TranslateTransform X="4" />
                        </Button.RenderTransform>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="10,8" />
                            </Style>
                        </Button.Style>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image x:Name="HomeIcon"
                                   Source="/Assets/Images/icons8-eclipse-50.png"
                                   Width="{x:Static abstractions:ThemeDimensions.HomeIconSize}"
                                   Height="{x:Static abstractions:ThemeDimensions.HomeIconSize}"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding DataContext.IsMenuCollapsed, ElementName=RootWindow, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <TextBlock x:Name="HomeText"
                                       Text="ホーム"
                                       FontFamily="{DynamicResource AppFontFamilyBold}"
                                       FontWeight="Normal"
                                       FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsMenuCollapsed, ElementName=RootWindow, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        </Grid>
                    </Button>

                    <ListBox Grid.Row="2"
                             Margin="0,0,0,0"
                             Style="{StaticResource NavListBoxStyle}"
                             ItemContainerStyle="{StaticResource NavListBoxItemStyle}"
                             ItemsSource="{Binding MenuItems}"
                             SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid>
                                        <Image Source="{Binding IconImagePath}">
                                            <Image.Style>
                                                <Style TargetType="Image" BasedOn="{StaticResource NavImageStyle}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <TextBlock Text="{Binding IconGlyph}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource NavIconStyle}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasIconImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource NavTextStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="0"
                                                                                     Duration="0:0:0.12">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseIn" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsMenuCollapsed, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                 Value="False">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     To="1"
                                                                                     BeginTime="0:0:0.1"
                                                                                     Duration="0:0:0.2">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut" />
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3"
                                Margin="0,4,0,14"
                                Orientation="Vertical"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom">
                        <Button Width="{x:Static abstractions:ThemeDimensions.IconButtonSize}"
                                Height="{x:Static abstractions:ThemeDimensions.IconButtonSize}"
                                HorizontalAlignment="Center"
                                Style="{StaticResource ThemeIconActionButtonStyle}"
                                Command="{Binding ReloadPluginsCommand}"
                                ToolTip="プラグインを再読み込み">
                            <Button.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard Name="RefreshSpinStoryboard">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RefreshRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0"
                                                             To="-360"
                                                             Duration="{StaticResource IconSpinDuration}"
                                                             RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <StopStoryboard BeginStoryboardName="RefreshSpinStoryboard" />
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RefreshRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             To="0"
                                                             Duration="{StaticResource IconSpinReturnDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Button.Triggers>

                            <Grid Width="{x:Static abstractions:ThemeDimensions.IconViewboxSmall}"
                                  Height="{x:Static abstractions:ThemeDimensions.IconViewboxSmall}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="True">
                                <Canvas Width="{x:Static abstractions:ThemeDimensions.IconCanvasSize}"
                                        Height="{x:Static abstractions:ThemeDimensions.IconCanvasSize}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Path Data="{StaticResource RefreshFrameOutlineGeometry}"
                                          Stroke="{DynamicResource PrimaryTextBrush}"
                                          StrokeThickness="{x:Static abstractions:ThemeDimensions.StrokeThin}"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"
                                          Opacity="{x:Static abstractions:ThemeDimensions.OpacitySubtle}" />
                                </Canvas>
                                <Canvas Width="{x:Static abstractions:ThemeDimensions.IconCanvasSize}"
                                        Height="{x:Static abstractions:ThemeDimensions.IconCanvasSize}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Canvas.RenderTransform>
                                        <RotateTransform x:Name="RefreshRotate"
                                                          Angle="0"
                                                          CenterX="12"
                                                          CenterY="12" />
                                    </Canvas.RenderTransform>
                                    <Path Data="{StaticResource RefreshArrowLeftGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                    <Path Data="{StaticResource RefreshArrowRightGeometry}"
                                          Fill="{DynamicResource PrimaryTextBrush}" />
                                </Canvas>
                            </Grid>
                        </Button>

                        <ToggleButton Margin="0,4,0,0"
                                      HorizontalAlignment="Center"
                                      IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                      Style="{StaticResource ThemeIconToggleStyle}" />

                        <TextBlock Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   MaxWidth="{x:Static abstractions:ThemeDimensions.PluginCountMaxWidth}"
                                   Text="{Binding PluginCountNavDisplay}"
                                   ToolTip="{Binding PluginCountText}"
                                   TextAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Style="{StaticResource SecondaryTextStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="Transparent" />
                <Border Grid.Row="1"
                        Margin="0,7,6,3"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        CornerRadius="{x:Static abstractions:ThemeDimensions.RadiusMedium}">
                    <ContentControl Margin="4"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    Content="{Binding CurrentView}" />
                </Border>

                <!-- Global Status Bar -->
                <Border Grid.Row="2"
                        Margin="0,0,12,12"
                        Height="{x:Static abstractions:ThemeDimensions.StatusBarHeight}"
                        Background="{DynamicResource NavBackgroundBrush}"
                        CornerRadius="{x:Static abstractions:ThemeDimensions.RadiusLarge}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding GlobalStatus.Message}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,12,0"
                                   Foreground="{Binding GlobalStatus.TextColor}"
                                   FontSize="{x:Static abstractions:ThemeDimensions.SmallFontSize}"
                                   TextTrimming="CharacterEllipsis"
                                   FontFamily="{DynamicResource AppFontFamilyBold}"
                                   FontWeight="Normal" />

                        <Border Grid.Column="1"
                                Margin="0,0,6,8"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                MinWidth="220"
                                CornerRadius="7"
                                Background="Transparent"
                                Visibility="{Binding GlobalStatus.ShowProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GlobalStatus.ShowProgress}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="{x:Static abstractions:ThemeDimensions.OpacityHover}"
                                                                         To="1"
                                                                         Duration="0:0:0.8" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.ColumnSpan="2"
                                        Background="Transparent"
                                        CornerRadius="6" />
                                <Border Grid.ColumnSpan="2"
                                        CornerRadius="6"
                                        Opacity="0"
                                        IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GlobalStatus.IsSuccessState}" Value="True">
                                                    <Setter Property="Background" Value="#FF2ECC71" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.75"
                                                                                 To="0"
                                                                                 Duration="0:0:0.55" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding GlobalStatus.IsErrorState}" Value="True">
                                                    <Setter Property="Background" Value="#FFFF5A5A" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="0.75"
                                                                                 To="0"
                                                                                 Duration="0:0:0.55" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <TextBlock Grid.Column="0"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontFamily="{DynamicResource AppFontFamilyBold}"
                                           FontSize="{x:Static abstractions:ThemeDimensions.MicroFontSize}"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding GlobalStatus.ProgressValue, StringFormat={}{0:0}%}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GlobalStatus.IsIndeterminate}" Value="True">
                                                    <Setter Property="Text" Value="..." />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ProgressBar Grid.Column="1"
                                             VerticalAlignment="Center"
                                             Height="{x:Static abstractions:ThemeDimensions.ProgressBarHeight}"
                                             Value="{Binding GlobalStatus.ProgressValue}"
                                             IsIndeterminate="{Binding GlobalStatus.IsIndeterminate}"
                                             Minimum="0"
                                             Maximum="100"
                                             Style="{StaticResource AppStatusProgressBarStyle}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,12,14,0"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Style="{StaticResource AboutAppStyle}"
                    Command="{Binding ShowAuthorCommand}" />
            <Button Style="{StaticResource ExitAppStyle}"
                    Click="CloseButton_Click"
                    ToolTip="閉じる" />
        </StackPanel>
    </Grid>
</Window>
