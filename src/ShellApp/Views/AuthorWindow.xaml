                                    <Path Fill="#393C54" Data="M49.57,56H54a6,6,0,0,1,6,6v3.56A2.41,2.41,0,0,1,57.59,68H45.41A2.41,2.41,0,0,1,43,65.59v-3A6.57,6.57,0,0,1,49.57,56Z">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="103" Y="124" />
                                                <RotateTransform Angle="180" />
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                    </Path>
                                    <Path Data="M70.41,56H82.59A2.41,2.41,0,0,1,85,58.41V62a6,6,0,0,1-6,6H74.57A6.57,6.57,0,0,1,68,61.43v-3A2.41,2.41,0,0,1,70.41,56Z"
                                          Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    <Path Data="M49.57,56H54a6,6,0,0,1,6,6v3.56A2.41,2.41,0,0,1,57.59,68H45.41A2.41,2.41,0,0,1,43,65.59v-3A6.57,6.57,0,0,1,49.57,56Z"
                                          Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="103" Y="124" />
                                                <RotateTransform Angle="180" />
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                    </Path>
                                    <Path Data="M60,62a4,4,0,0,1,8,0" Fill="Transparent" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="85" Y1="58.41" X2="92.32" Y2="52.5" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    <Line X1="43" Y1="58.41" X2="35.68" Y2="52.57" Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                                    <Path Fill="#515570" Opacity="0.1" Data="M91.61,66.29A9.71,9.71,0,0,0,83,76v9.83A38.42,38.42,0,0,0,91.61,66.29Z"/>
                                    <Path Fill="#515570" Opacity="0.1" Data="M36.42,66.31C37.89,74.62,41,81.17,44.88,86V76A9.72,9.72,0,0,0,36.42,66.31Z"/>

                                    <!-- 左侧工具 -->
                                    <Path Fill="#393C54" Data="M24.22,27H47.79a0,0,0,0,1,0,0v4.71A2.36,2.36,0,0,1,45.42,34H26.58a2.36,2.36,0,0,1-2.36-2.36V27a0,0,0,0,1,0,0Z">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="-11.02" Y="34.39" />
                                                <RotateTransform Angle="-45" />
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                    </Path>
                                    <Rectangle Width="28.28" Height="3.54" RadiusX="1.77" RadiusY="1.77"
                                               Canvas.Left="18.94" Canvas.Top="25.82" Fill="#F85565">
                                        <Rectangle.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="-9.81" Y="31.47" />
                                                <RotateTransform Angle="-45" />
                                            </TransformGroup>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                    <Path Fill="#FF8475" Data="M30.77,20.73l-8.94,8.94a2.35,2.35,0,0,0,0,3.33l1.67,1.67L40.17,18l-.41-.41A2.36,2.36,0,0,0,37,17.2l-5.66,3.14A2.53,2.53,0,0,0,30.77,20.73Z"/>

                                    <!-- 右侧工具 -->
                                    <Path Fill="#393C54" Data="M82.58,27h18.84a2.36,2.36,0,0,1,2.36,2.36V34a0,0,0,0,1,0,0H80.21a0,0,0,0,1,0,0V29.33A2.36,2.36,0,0,1,82.58,27Z">
                                        <Path.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="135.48" Y="117.12" />
                                                <RotateTransform Angle="-135" />
                                            </TransformGroup>
                                        </Path.RenderTransform>
                                    </Path>
                                    <Rectangle Width="28.28" Height="3.54" RadiusX="1.77" RadiusY="1.77"
                                               Canvas.Left="80.77" Canvas.Top="25.82" Fill="#F85565">
                                        <Rectangle.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="142.53" Y="114.2" />
                                                <RotateTransform Angle="-135" />
                                            </TransformGroup>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                    <Path Fill="#FF8475" Data="M97.23,20.73l8.94,8.94a2.35,2.35,0,0,1,0,3.33l-1.67,1.67L87.83,18l.41-.41a2.36,2.36,0,0,1,2.81-.39l5.66,3.14A2.53,2.53,0,0,1,97.23,20.73Z"/>

                                    <Path Fill="#515570" Data="M95.38,51.81l-10-9.24,4.07-4.41,10,9.23a3,3,0,0,1,.18,4.24h0A3,3,0,0,1,95.38,51.81Z"/>
                                    <Path Fill="#515570" Data="M32.38,51.81l10-9.24-4.07-4.41-10,9.23a3,3,0,0,0-.17,4.24h0A3,3,0,0,0,32.38,51.81Z"/>

                                    <Polyline Points="48,48 59,50 71,49 82,48"
                                              Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Opacity="0.1"/>
                                    <Polyline Points="47,51 60,54 69,53 82,53"
                                              Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Opacity="0.1"/>
                                    <Line X1="56" Y1="43" X2="61" Y2="58"
                                          Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.1"/>
                                    <Line X1="65" Y1="43" X2="64" Y2="58"
                                          Stroke="#515570" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.1"/>

                                    <Path Fill="#F2BC0F" Data="M37.69,96.5a14.18,14.18,0,0,0-3.08.34S36,106,44,110a19.32,19.32,0,0,1-4.87-13.5Z"/>
                                    <Path Fill="#F2BC0F" Data="M84,110c8-4,9.39-13.16,9.39-13.16a14.18,14.18,0,0,0-3.08-.34H88.87A19.32,19.32,0,0,1,84,110Z"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding DeveloperName}" Style="{StaticResource SubtitleTextStyle}" />
                                <TextBlock Text="{Binding DeveloperTeam}" Style="{StaticResource BodyTextStyle}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding ReleaseNotesHeading}"
                           Style="{StaticResource SubtitleTextStyle}"
                           Margin="4,0,0,16" />

                <ItemsControl ItemsSource="{Binding ReleaseNotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,16"
                                    Background="{DynamicResource NavBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    CornerRadius="8"
                                    Padding="20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                <Setter Property="BorderThickness" Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="{Binding VersionTitle}"
                                                   FontWeight="Bold" FontSize="15" Foreground="{DynamicResource PrimaryTextBrush}" HorizontalAlignment="Left" />
                                        <TextBlock Text="{Binding DateLabel}" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                    <TextBlock Text="{Binding Notes}"
                                               Style="{StaticResource CaptionTextStyle}" Foreground="{DynamicResource PrimaryTextBrush}" LineHeight="22" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="{Binding CloseButtonText}"
                Width="140"
                Height="40"
                Margin="0,0,0,18"
                Style="{DynamicResource PrimaryButtonStyle}"
                Command="{Binding CloseCommand}"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom" />
    </Grid>
</Window>
