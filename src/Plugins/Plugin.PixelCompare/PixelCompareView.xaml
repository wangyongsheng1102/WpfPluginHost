<UserControl x:Class="Plugin.PixelCompare.PixelCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Plugin.PixelCompare.Converters"
             FontSize="{DynamicResource BodyFontSize}"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <!-- サイズ不一致時の差異数（∞）用、ErrorBrush より濃い赤 -->
        <SolidColorBrush x:Key="PixelCompareInfinityForegroundBrush" Color="#7F0D0D" />
    </UserControl.Resources>
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,24" Padding="20"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="{StaticResource PanelRadius}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderSubtleBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Excelを選択"
                        Height="36"
                        MinWidth="110"
                        Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelCommand}" />

                <TextBlock Grid.Column="1"
                           Margin="12,0,16,0"
                           VerticalAlignment="Center"
                           Style="{DynamicResource BodyTextStyle}"
                           Text="{Binding ExcelPath}" />

                <Border Grid.Column="2"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="170"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              ItemsSource="{Binding AvailableSheets}"
                              SelectedItem="{Binding SelectedSheet, Mode=TwoWay}" />
                </Border>

                <Border Grid.Column="3"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="74"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding AvailableColumns}"
                              Text="{Binding LeftColumnName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <TextBlock Grid.Column="4"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Style="{DynamicResource CaptionTextStyle}"
                           Text="vs" />

                <Border Grid.Column="5"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="74"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding AvailableColumns}"
                              Text="{Binding RightColumnName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button Content="シートを再読込"
                            Height="36"
                            MinWidth="100"
                            Padding="12,0"
                            Margin="0,0,8,0"
                            Style="{DynamicResource ActionButtonStyle}"
                            IsEnabled="{Binding CanReloadSheetNames}"
                            Command="{Binding ReloadSheetNamesCommand}" />
                    <Button Content="レポート"
                            Height="36"
                            MinWidth="92"
                            Padding="12,0"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding ExportReportCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <!-- 比較一覧 : プレビュー = 4 : 6 -->
                <ColumnDefinition Width="4*" MinWidth="260" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="6*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="16"
                    Background="{DynamicResource CardElevatedBrush}"
                    CornerRadius="{StaticResource PanelRadius}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="比較一覧"
                               Style="{DynamicResource SubtitleTextStyle}"
                               Margin="0,0,0,10" />
                <DataGrid x:Name="CompareListDataGrid"
                          Grid.Row="1"
                          ItemsSource="{Binding CompareItems}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          VerticalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="38"
                          ColumnHeaderHeight="38"
                          FontSize="{DynamicResource BodyFontSize}"
                          FontFamily="{DynamicResource AppFontFamily}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          UseLayoutRounding="True"
                          ColumnHeaderStyle="{DynamicResource AppDataGridColumnHeaderStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="SnapsToDevicePixels" Value="True" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DataGridRowSelectedBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <!-- 合計が表示幅を超える場合は DataGrid 内で横スクロール -->
                        <DataGridTextColumn Header="行番号"
                                            Width="SizeToCells"
                                            MinWidth="64"
                                            Binding="{Binding RowIndex, Mode=OneWay}" />
                        <DataGridTextColumn Header="結果"
                                            Width="SizeToCells"
                                            MinWidth="88"
                                            Binding="{Binding StatusText, Mode=OneWay}" />
                        <DataGridTextColumn Header="差異率"
                                            Width="SizeToCells"
                                            MinWidth="120"
                                            Binding="{Binding DifferencePercentageText, Mode=OneWay}" />
                        <DataGridTextColumn Header="差異数"
                                            Width="*"
                                            MinWidth="72"
                                            Binding="{Binding DiffCountDisplay, Mode=OneWay}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="{DynamicResource BodyFontSize}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSizeMismatch}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource PixelCompareInfinityForegroundBrush}" />
                                            <Setter Property="FontSize" Value="{DynamicResource SubtitleFontSize}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasNonZeroDiffCount}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16"
                    Background="{DynamicResource CardElevatedBrush}"
                    CornerRadius="{StaticResource PanelRadius}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="結果プレビュー"
                               Style="{DynamicResource SubtitleTextStyle}"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="左画像"
                                Height="30"
                                MinWidth="70"
                                Style="{DynamicResource PreviewLeftToggleButtonStyle}"
                                Command="{Binding ShowLeftImageCommand}" />
                        <Button Content="右画像"
                                Margin="8,0,0,0"
                                Height="30"
                                MinWidth="70"
                                Style="{DynamicResource PreviewRightToggleButtonStyle}"
                                Command="{Binding ShowRightImageCommand}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{DynamicResource NavBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            CornerRadius="{StaticResource PanelRadius}">
                        <Grid>
                            <Image Source="{Binding PreviewImagePath}"
                                   Stretch="Uniform"
                                   PreviewMouseLeftButtonDown="OnPreviewImageMouseLeftButtonDown">
                                <Image.ToolTip>
                                    <ToolTip>
                                        <TextBlock Style="{DynamicResource BodyTextStyle}"
                                                   Text="画像をダブルクリックすると既定の画像ビューアで開きます"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="280" />
                                    </ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <TextBlock Text="左側の行を選択すると結果画像を表示します"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PreviewImagePath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PreviewImagePath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
