<UserControl x:Class="Plugin.PixelCompare.PixelCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Plugin.PixelCompare.Converters"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <!-- サイズ不一致時の差異数（∞）用、ErrorBrush より濃い赤 -->
        <SolidColorBrush x:Key="PixelCompareInfinityForegroundBrush" Color="#7F0D0D" />
    </UserControl.Resources>
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,24" Padding="20"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="{StaticResource PanelRadius}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderSubtleBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.Column="0"
                        Content="Excelを選択"
                        Height="36"
                        MinWidth="110"
                        Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelCommand}" />

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Margin="12,0,16,0"
                           VerticalAlignment="Center"
                           Style="{DynamicResource BodyTextStyle}"
                           Text="{Binding ExcelPath}" />

                <Border Grid.Row="0" Grid.Column="2"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="170"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              ItemsSource="{Binding AvailableSheets}"
                              SelectedItem="{Binding SelectedSheet, Mode=TwoWay}" />
                </Border>

                <Border Grid.Row="0" Grid.Column="3"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="90"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding AvailableColumns}"
                              Text="{Binding LeftColumnName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <TextBlock Grid.Row="0" Grid.Column="4"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Style="{DynamicResource CaptionTextStyle}"
                           Text="vs" />

                <Border Grid.Row="0" Grid.Column="5"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="36"
                        Width="90"
                        Margin="0,0,8,0">
                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                              IsEditable="True"
                              ItemsSource="{Binding AvailableColumns}"
                              Text="{Binding RightColumnName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Border>

                <StackPanel Grid.Row="0" Grid.Column="6" Orientation="Horizontal">
                    <Button Content="シートを再読込"
                            Height="36"
                            MinWidth="100"
                            Padding="12,0"
                            Margin="0,0,8,0"
                            Style="{DynamicResource ActionButtonStyle}"
                            IsEnabled="{Binding CanReloadSheetNames}"
                            Command="{Binding ReloadSheetNamesCommand}" />
                    <Button Content="レポート"
                            Height="36"
                            MinWidth="92"
                            Padding="12,0"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding ExportReportCommand}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      Grid.Column="0"
                      Grid.ColumnSpan="7"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="70" />
                        </Grid.ColumnDefinitions>
                        <Grid.ToolTip>
                            <ToolTip>
                                <TextBlock Style="{DynamicResource BodyTextStyle}"
                                           Text="通常は既定値（35）のままご利用ください。変更が必要な場合は、管理者にご確認のうえでお願いいたします。"
                                           TextWrapping="Wrap"
                                           MaxWidth="280" />
                            </ToolTip>
                        </Grid.ToolTip>
                        <TextBlock Grid.Column="0"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Style="{DynamicResource CaptionTextStyle}"
                                   Text="閾値" />
                        <Border Grid.Column="1"
                                Style="{DynamicResource AppInputChromeBorderStyle}"
                                Height="32">
                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                                     IsReadOnly="{Binding IsDiffThresholdReadOnly}"
                                     PreviewMouseLeftButtonDown="OnDiffThresholdTextBoxPreviewMouseLeftButtonDown"
                                     Text="{Binding DiffThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </Grid>

                    <TextBlock Grid.Column="3"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Style="{DynamicResource CaptionTextStyle}"
                               Text="最小領域" />
                    <Border Grid.Column="4"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                                 IsEnabled="False"
                                 Text="{Binding MinRegionAreaText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Grid.Column="6"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Style="{DynamicResource CaptionTextStyle}"
                               Text="結合距離" />
                    <Border Grid.Column="7"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                                 IsEnabled="False"
                                 Text="{Binding MergeDistanceText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Grid.Column="9"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Style="{DynamicResource CaptionTextStyle}"
                               Text="膨張px" />
                    <Border Grid.Column="10"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                                 IsEnabled="False"
                                 Text="{Binding ExpandPixelsText, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <!-- 比較一覧エリアはテーブルの内容幅に追従、プレビューは残り幅を使用 -->
                <ColumnDefinition Width="Auto" MinWidth="0" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="12,16"
                    Background="{DynamicResource CardElevatedBrush}"
                    CornerRadius="{StaticResource PanelRadius}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="比較一覧"
                               Style="{DynamicResource SubtitleTextStyle}"
                               Margin="0,0,0,10" />
                    <Grid Grid.Row="1" Grid.IsSharedSizeScope="True" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 列見出し（DataGrid 版と同じ列を LeftTable / ItemTemplate に复刻） -->
                        <Grid Grid.Row="0" Margin="8,0,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcRowIndex" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcStatus" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcDiffCount" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcDiffPct" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="RowIndex">
                                <TextBlock Text="{Binding RowIndexHeaderText}"
                                           Style="{DynamicResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="2"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="StatusText">
                                <TextBlock Text="{Binding StatusHeaderText}"
                                           Style="{DynamicResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="4"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="SortDiffCount">
                                <TextBlock Text="{Binding DiffCountHeaderText}"
                                           Style="{DynamicResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <Button Grid.Column="6"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand"
                                    Command="{Binding SortByCommand}"
                                    CommandParameter="DifferencePercentage">
                                <TextBlock Text="{Binding DiffPctHeaderText}"
                                           Style="{DynamicResource CaptionTextStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding CompareItemsView}"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InverseBooleanConverter}}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalAlignment="Left"
                                 HorizontalContentAlignment="Left"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionMode="Single"
                                 >
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem"
                                       BasedOn="{StaticResource AppFlatSelectableRowListBoxItemStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcRowIndex" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcStatus" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcDiffCount" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="PcDiffPct" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding RowIndex}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       TextAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding StatusText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       TextAlignment="Center" />

                                            <Border Grid.Column="4" Background="Transparent">
                                                <Border.Resources>
                                                    <Style x:Key="PcDiffCountTextStyle" TargetType="TextBlock">
                                                        <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                                                        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                                        <Setter Property="TextAlignment" Value="Center" />
                                                    </Style>
                                                </Border.Resources>
                                                <TextBlock Text="{Binding DiffCountDisplay}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource PcDiffCountTextStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasInfinityStyleDiffCount}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource PixelCompareInfinityForegroundBrush}" />
                                                                    <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.SubtitleFontSize}" />
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding HasNonZeroDiffCount}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding DifferencePercentageText}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16"
                    Background="{DynamicResource CardElevatedBrush}"
                    CornerRadius="{StaticResource PanelRadius}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="結果プレビュー"
                               Style="{DynamicResource SubtitleTextStyle}"
                               Margin="0,0,0,8" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="左画像"
                                Height="30"
                                MinWidth="70"
                                Style="{DynamicResource PreviewLeftToggleButtonStyle}"
                                Command="{Binding ShowLeftImageCommand}" />
                        <Button Content="右画像"
                                Margin="8,0,0,0"
                                Height="30"
                                MinWidth="70"
                                Style="{DynamicResource PreviewRightToggleButtonStyle}"
                                Command="{Binding ShowRightImageCommand}" />
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{DynamicResource NavBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            CornerRadius="{StaticResource PanelRadius}">
                        <Grid>
                            <Image Source="{Binding PreviewImagePath}"
                                   Stretch="Uniform"
                                   PreviewMouseLeftButtonDown="OnPreviewImageMouseLeftButtonDown">
                                <Image.ToolTip>
                                    <ToolTip>
                                        <TextBlock Style="{DynamicResource BodyTextStyle}"
                                                   Text="画像をダブルクリックすると既定の画像ビューアで開きます"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="280" />
                                    </ToolTip>
                                </Image.ToolTip>
                            </Image>
                            <TextBlock Text="左側の行を選択すると結果画像を表示します"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PreviewImagePath}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PreviewImagePath}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
