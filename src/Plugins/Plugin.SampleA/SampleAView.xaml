<UserControl x:Class="Plugin.SampleA.SampleAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackgroundBrush}"
             AllowDrop="True" Drop="OnDrop" DragEnter="OnDragEnter" DragOver="OnDragOver">
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 書式設定オプション -->
        <Border Grid.Row="0" Margin="0,0,0,24" Padding="20"
                Background="{DynamicResource NavBackgroundBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource HoverBrush}">
            <StackPanel>
                <TextBlock Text="書式設定オプション" FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <CheckBox Content="すべてのワークシートの表示倍率をリセット：" 
                              IsChecked="{Binding EnableZoomFormat}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              VerticalAlignment="Center" FontSize="14" />
                    <Border Background="{DynamicResource NavBackgroundBrush}"
                            BorderBrush="{DynamicResource HoverBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="8,0,0,0" Width="60" Height="28">
                        <TextBox Text="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding EnableZoomFormat}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="0,0" VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"/>
                    </Border>
                    <TextBlock Text="%" Foreground="{DynamicResource PrimaryTextBrush}" 
                               VerticalAlignment="Center" Margin="6,0,0,0" FontSize="14"/>
                </StackPanel>
                          
                <CheckBox Content="すべてのワークシートのアクティブセルを A1 に合わせる" 
                          IsChecked="{Binding FormatFocusA1}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,12" FontSize="14" />
                          
                <CheckBox Content="処理後は先頭のワークシートのみをアクティブにする" 
                          IsChecked="{Binding FormatActiveFirstSheet}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,12" FontSize="14" />

                <CheckBox Content="外部ブックへのリンクをすべて切断する（Break Links）" 
                          IsChecked="{Binding BreakExternalLinks}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          FontSize="14" />
            </StackPanel>
        </Border>

        <!-- 一覧／ドロップ領域 -->
        <Border Grid.Row="1" Margin="0,0,0,24"
                Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource HoverBrush}"
                BorderThickness="2" CornerRadius="8">
            <Grid>
                <!-- キューが空のときの表示 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📥" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="Excel ファイルまたはフォルダーをここにドロップしてタスクキューに追加" 
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="フォルダーをドロップした場合、その中の Excel ファイルを自動でスキャンします" 
                               FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,8,0,0" Opacity="0.7"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid オーバーレイ -->
                <DataGrid ItemsSource="{Binding PendingFiles}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="36"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource NavBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter Property="Padding" Value="10,8" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}" Width="250" IsReadOnly="True" />
                        <DataGridTextColumn Header="状態" Binding="{Binding Status}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="パス" Binding="{Binding FilePath}" Width="*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 下部のアクションバー -->
        <Border Grid.Row="2" Padding="20,16"
                Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource HoverBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左：追加・クリア -->
                <Button Grid.Column="0" Content="＋ 手動で追加…" 
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelFallbackCommand}" />
                        
                <Button Grid.Column="1" Content="🗑 キューをクリア"
                        MinWidth="100" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding ClearFilesCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />

                <!-- 中央：ステータス -->
                <TextBlock Grid.Column="2"
                           Margin="24,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <!-- 右：書式設定の実行 -->
                <Button Grid.Column="3" Content="🚀 書式設定を実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ExecuteFormatCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
