<UserControl x:Class="Plugin.SampleA.SampleAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="InputRecorderStopButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 書式設定オプション -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="20"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderSubtleBrush}">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <TextBlock Text="書式設定オプション"
                               Style="{StaticResource SubtitleTextStyle}"
                               VerticalAlignment="Center" />
                    <CheckBox Content="全て"
                              IsChecked="{Binding SelectAll}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 表示設定 -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="表示設定" Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <CheckBox Content="ズーム倍率リセット："
                                      IsChecked="{Binding OptZoomReset}"
                                      FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                            <Border Background="{DynamicResource NavBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1" CornerRadius="4"
                                    Margin="4,0,0,0" MinWidth="48" Height="26" VerticalAlignment="Center">
                                <TextBox Text="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding OptZoomReset}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         CaretBrush="{DynamicResource PrimaryTextBrush}"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="4,1" VerticalContentAlignment="Center"
                                         HorizontalContentAlignment="Center"
                                         FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                            </Border>
                            <TextBlock Text="%" Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center" Margin="2,0,0,0"
                                       FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                        </StackPanel>

                        <CheckBox Content="カーソルを A1 セルに移動"
                                  IsChecked="{Binding OptCursorA1}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="最初のシートをアクティブ化"
                                  IsChecked="{Binding OptActiveFirstSheet}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="スクロール位置を左上に戻す"
                                  IsChecked="{Binding OptScrollTopLeft}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                    </StackPanel>

                    <!-- データ整理 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="データ整理" Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />

                        <CheckBox Content="フィルターを解除"
                                  IsChecked="{Binding OptClearFilters}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="数式を値に固定"
                                  IsChecked="{Binding OptFormulaToValue}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="外部リンクを切断"
                                  IsChecked="{Binding OptBreakExternalLinks}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="コメント・メモを削除"
                                  IsChecked="{Binding OptRemoveComments}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="条件付き書式を削除"
                                  IsChecked="{Binding OptClearConditionalFormats}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                    </StackPanel>

                    <!-- レイアウト＆印刷 -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="レイアウト調整" Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />

                        <CheckBox Content="列幅の自動調整"
                                  IsChecked="{Binding OptAutoFitColumns}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="行高の自動調整"
                                  IsChecked="{Binding OptAutoFitRows}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="ウィンドウ枠固定を解除"
                                  IsChecked="{Binding OptUnfreezePanes}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="非表示シートを再表示"
                                  IsChecked="{Binding OptUnhideSheets}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="非表示の行・列を再表示"
                                  IsChecked="{Binding OptUnhideRowsCols}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <TextBlock Text="印刷設定" Style="{StaticResource CaptionTextStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,12,0,8" />

                        <CheckBox Content="印刷範囲をリセット"
                                  IsChecked="{Binding OptResetPrintArea}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="用紙を横向きに設定"
                                  IsChecked="{Binding OptSetLandscape}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="1ページに収める"
                                  IsChecked="{Binding OptFitToOnePage}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="余白を標準値にリセット"
                                  IsChecked="{Binding OptResetMargins}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                        <CheckBox Content="ヘッダー／フッター設定"
                                  IsChecked="{Binding OptSetHeaderFooter}"
                                  Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 一覧／ドロップ領域 -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                CornerRadius="8"
                AllowDrop="True"
                PreviewDrop="OnDropZonePreviewDrop"
                PreviewDragOver="OnDropZonePreviewDragOver"
                PreviewDragLeave="OnDropZonePreviewDragLeave"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragOverDropZone}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource IndicatorBrush}" />
                            <Setter Property="BorderThickness" Value="3" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Border CornerRadius="6" Margin="4" IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOverDropZone}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
                                    <Setter Property="Opacity" Value="0.12" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- 空状態 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Excel ファイルまたはフォルダをこのエリアにドラッグ＆ドロップ"
                               Style="{StaticResource SubtitleTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="フォルダをドロップした場合、フォルダ内のすべての Excel ファイルを自動的にスキャンします"
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0" Opacity="0.7"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid x:Name="PendingFilesDataGrid"
                          ItemsSource="{Binding PendingFiles}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False" CanUserResizeRows="False"
                          HeadersVisibility="Column" SelectionMode="Single" SelectionUnit="FullRow"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          VerticalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          Background="Transparent" BorderThickness="0"
                          RowHeight="40" ColumnHeaderHeight="40"
                          FontFamily="{DynamicResource AppFontFamily}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          UseLayoutRounding="True"
                          ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ファイル名" Binding="{Binding FileName}"
                                            Width="SizeToCells" MinWidth="125" IsReadOnly="True"
                                            ElementStyle="{StaticResource DataGridTextColumnElementStyle}" />
                        <DataGridTextColumn Header="ステータス" Binding="{Binding Status}"
                                            Width="SizeToCells" MinWidth="60" IsReadOnly="True"
                                            ElementStyle="{StaticResource DataGridTextColumnElementStyle}" />
                        <DataGridTextColumn Header="パス" Binding="{Binding FilePath}"
                                            Width="*" IsReadOnly="True"
                                            ElementStyle="{StaticResource DataGridTextColumnElementStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- アクションバー -->
        <Border Grid.Row="2" Padding="10,8"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="+ 手動追加..."
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelFallbackCommand}" />

                <Button Grid.Column="1" Content="🗑 キューをクリア"
                        MinWidth="100" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding ClearFilesCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />

                <TextBlock Grid.Column="2"
                           Margin="12,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Style="{StaticResource KeyInfoTextStyle}"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <Button Grid.Column="3" Content="🚀 書式設定を実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ExecuteFormatCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
