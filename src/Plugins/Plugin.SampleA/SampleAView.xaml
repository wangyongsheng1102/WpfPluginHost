<UserControl x:Class="Plugin.SampleA.SampleAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ContentBackgroundBrush}"
             AllowDrop="True" Drop="OnDrop" DragEnter="OnDragEnter" DragOver="OnDragOver">
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Configuration Options -->
        <Border Grid.Row="0" Margin="0,0,0,24" Padding="20"
                Background="{DynamicResource NavBackgroundBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource HoverBrush}">
            <StackPanel>
                <TextBlock Text="格式化选项" FontSize="18" FontWeight="SemiBold" 
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <CheckBox Content="重置所有工作表缩放比例：" 
                              IsChecked="{Binding EnableZoomFormat}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              VerticalAlignment="Center" FontSize="14" />
                    <Border Background="{DynamicResource NavBackgroundBrush}"
                            BorderBrush="{DynamicResource HoverBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="8,0,0,0" Width="60" Height="28">
                        <TextBox Text="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding EnableZoomFormat}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="0,0" VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"/>
                    </Border>
                    <TextBlock Text="%" Foreground="{DynamicResource PrimaryTextBrush}" 
                               VerticalAlignment="Center" Margin="6,0,0,0" FontSize="14"/>
                </StackPanel>
                          
                <CheckBox Content="所有工作表光标焦点归位到 A1 单元格" 
                          IsChecked="{Binding FormatFocusA1}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,12" FontSize="14" />
                          
                <CheckBox Content="处理完成后默认只激活第一页工作表" 
                          IsChecked="{Binding FormatActiveFirstSheet}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,12" FontSize="14" />

                <CheckBox Content="自动断开所有的外部文件链接 (Break Links)" 
                          IsChecked="{Binding BreakExternalLinks}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          FontSize="14" />
            </StackPanel>
        </Border>

        <!-- List / Drop Zone -->
        <Border Grid.Row="1" Margin="0,0,0,24"
                Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource HoverBrush}"
                BorderThickness="2" CornerRadius="8">
            <Grid>
                <!-- Empty Placeholder -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="📥" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="将 Excel 文件或文件夹拖放到此区域建立任务队列" 
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="若拖入文件夹，将自动扫描其中的所有 Excel 文件" 
                               FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,8,0,0" Opacity="0.7"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid overlay -->
                <DataGrid ItemsSource="{Binding PendingFiles}"
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="36"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource NavBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource HoverBrush}" />
                            <Setter Property="Padding" Value="10,8" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="10,6" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SelectedBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="250" IsReadOnly="True" />
                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120" IsReadOnly="True" />
                        <DataGridTextColumn Header="路径" Binding="{Binding FilePath}" Width="*" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Bottom Action Bar -->
        <Border Grid.Row="2" Padding="20,16"
                Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource HoverBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Actions: Add & Clear -->
                <Button Grid.Column="0" Content="+ 手动添加..." 
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelFallbackCommand}" />
                        
                <Button Grid.Column="1" Content="🗑 清空队列"
                        MinWidth="100" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding ClearFilesCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />

                <!-- Center: Pinned Status Text -->
                <TextBlock Grid.Column="2"
                           Margin="24,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <!-- Right Action: Primary Execute (Accented) -->
                <Button Grid.Column="3" Content="🚀 开始执行格式化"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding ExecuteFormatCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
