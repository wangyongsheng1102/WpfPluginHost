<UserControl x:Class="Plugin.SampleA.SampleAView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 書式設定オプション -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="10"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderSubtleBrush}">
            <StackPanel>
                <TextBlock Text="書式設定オプション"
                           Margin="0,0,0,8"
                           Style="{StaticResource SubtitleTextStyle}"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox Content="すべてのシートのズーム倍率をリセットする：" 
                              IsChecked="{Binding EnableZoomFormat}"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              VerticalAlignment="Center" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                    <Border Background="{DynamicResource NavBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Margin="8,0,0,0" MinWidth="56" Height="28" VerticalAlignment="Center">
                        <TextBox Text="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding EnableZoomFormat}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="6,2" VerticalContentAlignment="Center"
                                 HorizontalContentAlignment="Center"
                                 FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"/>
                    </Border>
                    <TextBlock Text="%" Foreground="{DynamicResource PrimaryTextBrush}" 
                               VerticalAlignment="Center" Margin="3,0,0,0" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"/>
                </StackPanel>
                          
                <CheckBox Content="すべてのシートのカーソルを A1 セルに移動する" 
                          IsChecked="{Binding FormatFocusA1}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                          
                <CheckBox Content="処理完了後、デフォルトで最初のシートをアクティブにする" 
                          IsChecked="{Binding FormatActiveFirstSheet}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          Margin="0,0,0,6" FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />

                <TextBlock Text="処理時に自動実行：フィルター解除・数式を値に固定・行列の自動調整・外部リンク切断"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Style="{StaticResource CaptionTextStyle}"
                           Opacity="0.86" />
            </StackPanel>
        </Border>

        <!-- 一覧／ドロップ領域 -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                CornerRadius="8"
                AllowDrop="True"
                PreviewDrop="OnDropZonePreviewDrop"
                PreviewDragOver="OnDropZonePreviewDragOver"
                PreviewDragLeave="OnDropZonePreviewDragLeave"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragOverDropZone}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource IndicatorBrush}" />
                            <Setter Property="BorderThickness" Value="3" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Border CornerRadius="6"
                        Margin="4"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Opacity" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOverDropZone}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource IndicatorBrush}" />
                                    <Setter Property="Opacity" Value="0.12" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- キューが空のときの表示 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Viewbox Width="84"
                             Height="84"
                             Stretch="Uniform"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,8">
                        <Viewbox.Resources>
                            <LinearGradientBrush x:Key="SampleADropExcelPaint0"
                                                 MappingMode="Absolute"
                                                 StartPoint="8,26.5"
                                                 EndPoint="32,26.5">
                                <GradientStop Offset="0" Color="#163C27" />
                                <GradientStop Offset="1" Color="#2A6043" />
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="SampleADropExcelPaint1"
                                                 MappingMode="Absolute"
                                                 StartPoint="0,16"
                                                 EndPoint="18,16">
                                <GradientStop Offset="0" Color="#185A30" />
                                <GradientStop Offset="1" Color="#176F3D" />
                            </LinearGradientBrush>
                        </Viewbox.Resources>
                        <Canvas Width="32" Height="32" SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <ScaleTransform ScaleX="1.16" ScaleY="1.16" />
                            </Canvas.RenderTransform>
                            <Rectangle Canvas.Left="8"
                                       Canvas.Top="2"
                                       Width="24"
                                       Height="28"
                                       RadiusX="2"
                                       RadiusY="2"
                                       Fill="#2FB776" />
                            <Path Fill="{StaticResource SampleADropExcelPaint0}"
                                  Data="M8,23 H32 V28 C32,29.1046 31.1046,30 30,30 H10 C8.89543,30 8,29.1046 8,28 V23 Z" />
                            <Rectangle Canvas.Left="20"
                                       Canvas.Top="16"
                                       Width="12"
                                       Height="7"
                                       Fill="#229C5B" />
                            <Rectangle Canvas.Left="20"
                                       Canvas.Top="9"
                                       Width="12"
                                       Height="7"
                                       Fill="#27AE68" />
                            <Path Fill="#1D854F"
                                  Data="M8,4 C8,2.89543 8.89543,2 10,2 H20 V9 H8 V4 Z" />
                            <Rectangle Canvas.Left="8"
                                       Canvas.Top="9"
                                       Width="12"
                                       Height="7"
                                       Fill="#197B43" />
                            <Rectangle Canvas.Left="8"
                                       Canvas.Top="16"
                                       Width="12"
                                       Height="7"
                                       Fill="#1B5B38" />
                            <Path Fill="#4D000000"
                                  Data="M8,12 C8,10.3431 9.34315,9 11,9 H17 C18.6569,9 20,10.3431 20,12 V24 C20,25.6569 18.6569,27 17,27 H8 V12 Z" />
                            <Rectangle Canvas.Left="0"
                                       Canvas.Top="7"
                                       Width="18"
                                       Height="18"
                                       RadiusX="2"
                                       RadiusY="2"
                                       Fill="{StaticResource SampleADropExcelPaint1}" />
                            <Path Fill="White"
                                  Data="M13,21 L10.1821,15.9 L12.8763,11 H10.677 L9.01375,14.1286 L7.37801,11 H5.10997 L7.81787,15.9 L5,21 H7.19931 L8.97251,17.6857 L10.732,21 H13 Z" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Excel ファイルまたはフォルダをこのエリアにドラッグ＆ドロップして、タスクキューを作成します" 
                               Style="{StaticResource SubtitleTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="フォルダをドロップした場合、フォルダ内のすべての Excel ファイルを自動的にスキャンします" 
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0" Opacity="0.7"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid オーバーレイ -->
                <DataGrid x:Name="PendingFilesDataGrid"
                          ItemsSource="{Binding PendingFiles}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          VerticalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="40"
                          ColumnHeaderHeight="40"
                          FontFamily="{DynamicResource AppFontFamily}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          UseLayoutRounding="True"
                          ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}">
                    <DataGrid.Resources>
                        <!-- DataGridTextColumn の生成要素はテーマによって下線っぽく見えることがあるため、
                             テンプレート列では TextBlock に直接 TextDecorations を付与する -->
                        <Style x:Key="SampleADataGridCellTextStyle" TargetType="TextBlock" BasedOn="{x:Null}">
                            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
                            <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="TextWrapping" Value="NoWrap" />
                            <Setter Property="TextDecorations">
                                <Setter.Value>
                                    <TextDecorationCollection />
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}"
                                             Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingFiles}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="ファイル名"
                                                Width="SizeToCells"
                                                MinWidth="125"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{DynamicResource SampleADataGridCellTextStyle}"
                                               Text="{Binding FileName}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ステータス"
                                                Width="SizeToCells"
                                                MinWidth="60"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="4,2"
                                            CornerRadius="10"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#143B82F6" />
                                                <Setter Property="BorderBrush" Value="#663B82F6" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="✅ 完了">
                                                        <Setter Property="Background" Value="#1634D399" />
                                                        <Setter Property="BorderBrush" Value="#6645D5A4" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="❌ 失敗">
                                                        <Setter Property="Background" Value="#1AF87171" />
                                                        <Setter Property="BorderBrush" Value="#66F87171" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="処理中...">
                                                        <Setter Property="Background" Value="#14F59E0B" />
                                                        <Setter Property="BorderBrush" Value="#66F59E0B" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="待機中">
                                                        <Setter Property="Background" Value="#144B5563" />
                                                        <Setter Property="BorderBrush" Value="#665B6471" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}"
                                                   Style="{DynamicResource SampleADataGridCellTextStyle}"
                                                   ToolTip="{Binding StatusDetail}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="パス"
                                                Width="*"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{DynamicResource SampleADataGridCellTextStyle}"
                                               Text="{Binding FilePath}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 下部のアクションバー -->
        <Border Grid.Row="2" Padding="10,8"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左：追加・クリア -->
                <Button Grid.Column="0" Content="+ 手動追加..." 
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SelectExcelFallbackCommand}" />
                        
                <Button Grid.Column="1" Content="🗑 キューをクリア"
                        MinWidth="100" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding ClearFilesCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />

                <!-- 中央：ステータス -->
                <TextBlock Grid.Column="2"
                           Margin="12,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Style="{StaticResource KeyInfoTextStyle}"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <!-- 右：書式設定の実行 -->
                <Button Grid.Column="3" Content="🚀 書式設定を実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ExecuteFormatCommand}"
                        IsEnabled="{Binding HasPendingFiles}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
