<UserControl x:Class="Plugin.ReviewCheck.Views.ReviewCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="10"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="成果物ルート（SVN）" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,0,10,8"
                         MinHeight="28"
                         Padding="8,4"
                         Text="{Binding SvnRootPath, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource NavBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderSubtleBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         CaretBrush="{DynamicResource PrimaryTextBrush}" />
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,0,0,8"
                        MinHeight="28"
                        Padding="10,4"
                        Content="参照…"
                        Command="{Binding BrowseSvnRootCommand}"
                        Style="{DynamicResource ActionButtonStyle}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="WBS（作成者/確認者）" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="0,0,10,8"
                         MinHeight="28"
                         Padding="8,4"
                         Text="{Binding WbsExcelPath, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource NavBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderSubtleBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         CaretBrush="{DynamicResource PrimaryTextBrush}" />
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,0,8"
                        MinHeight="28"
                        Padding="10,4"
                        Content="参照…"
                        Command="{Binding BrowseWbsExcelCommand}"
                        Style="{DynamicResource ActionButtonStyle}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="機能ID（任意）" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,10,8"
                         MinHeight="28"
                         Padding="8,4"
                         Text="{Binding FunctionId, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource NavBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderSubtleBrush}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         CaretBrush="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,0,0,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="" />

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinHeight="30"
                            Padding="12,6"
                            Margin="0,0,10,0"
                            Content="実行"
                            Command="{Binding RunChecksCommand}"
                            IsEnabled="{Binding CanRun}"
                            Style="{DynamicResource ActionButtonStyle}" />
                    <Button MinHeight="30"
                            Padding="12,6"
                            Margin="0,0,10,0"
                            Content="JSON出力…"
                            Command="{Binding ExportJsonCommand}"
                            IsEnabled="{Binding HasResults}"
                            Style="{DynamicResource ActionButtonStyle}" />
                    <Button MinHeight="30"
                            Padding="12,6"
                            Content="結果をクリア"
                            Command="{Binding ClearResultsCommand}"
                            Style="{DynamicResource ActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="12,10,12,8"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="{Binding SummaryText}" />

                <DataGrid Grid.Row="1"
                          Margin="12,0,12,12"
                          ItemsSource="{Binding Results}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ステップ" Binding="{Binding Step}" Width="140" />
                        <DataGridTextColumn Header="結果" Binding="{Binding Status}" Width="70" />
                        <DataGridTextColumn Header="重要度" Binding="{Binding Severity}" Width="80" />
                        <DataGridTextColumn Header="Sheet" Binding="{Binding SheetName}" Width="160" />
                        <DataGridTextColumn Header="Cell" Binding="{Binding CellRef}" Width="80" />
                        <DataGridTextColumn Header="メッセージ" Binding="{Binding Message}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
