<UserControl x:Class="Plugin.ReviewCheck.Views.ReviewCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="10"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="成果物ルート（SVN）" />
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Margin="0,0,10,8"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="32">
                    <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                             Text="{Binding SvnRootPath, UpdateSourceTrigger=PropertyChanged}" />
                </Border>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        Margin="0,0,0,8"
                        Height="32"
                        Padding="10,4"
                        Content="参照…"
                        Command="{Binding BrowseSvnRootCommand}"
                        Style="{DynamicResource ActionButtonStyle}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,0,10,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="WBSファイル" />
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Margin="0,0,10,8"
                        Style="{DynamicResource AppInputChromeBorderStyle}"
                        Height="32">
                    <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                             Text="{Binding WbsExcelPath, UpdateSourceTrigger=PropertyChanged}" />
                </Border>
                <Button Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,0,8"
                        Height="32"
                        Padding="10,4"
                        Content="参照…"
                        Command="{Binding BrowseWbsExcelCommand}"
                        Style="{DynamicResource ActionButtonStyle}" />

                <Grid Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Margin="0,0,10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="170" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                               Text="機能ID" />
                    <Border Grid.Column="1"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <TextBox Style="{DynamicResource AppTextBoxFlatStyle}"
                                 Text="{Binding FunctionId, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <TextBlock Grid.Column="3"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                               Text="区分" />
                    <Border Grid.Column="4"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                  SelectedItem="{Binding InputType}"
                                  ItemsSource="{Binding InputTypeOptions}" />
                    </Border>

                    <TextBlock Grid.Column="6"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                               Text="System" />
                    <Border Grid.Column="7"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                  SelectedItem="{Binding SystemName}"
                                  ItemsSource="{Binding SystemOptions}" />
                    </Border>

                    <TextBlock Grid.Column="9"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                               Text="对象区分" />
                    <Border Grid.Column="10"
                            Style="{DynamicResource AppInputChromeBorderStyle}"
                            Height="32">
                        <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                  SelectedItem="{Binding ObjectName}"
                                  ItemsSource="{Binding ObjectOptions}" />
                    </Border>
                </Grid>
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Margin="0,0,0,8"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="" />

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button MinHeight="30"
                            Padding="12,6"
                            Margin="0,0,10,0"
                            Content="実行"
                            Command="{Binding RunChecksCommand}"
                            IsEnabled="{Binding CanRun}"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button MinHeight="30"
                            Padding="12,6"
                            Margin="0,0,10,0"
                            Content="JSON出力…"
                            Command="{Binding ExportJsonCommand}"
                            IsEnabled="{Binding HasResults}"
                            Style="{DynamicResource ActionButtonStyle}" />
                    <Button MinHeight="30"
                            Padding="12,6"
                            Content="結果をクリア"
                            Command="{Binding ClearResultsCommand}"
                            Style="{DynamicResource ActionButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Margin="12,10,12,8"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           FontSize="{x:Static abstractions:ThemeDimensions.CaptionFontSize}"
                           Text="{Binding SummaryText}" />

                <Grid Grid.Row="1"
                      Grid.IsSharedSizeScope="True"
                      Margin="12,0,12,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcStep" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcStatus" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcSeverity" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcSheet" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcCell" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="ステップ" Style="{DynamicResource CaptionTextStyle}" />
                        <TextBlock Grid.Column="2" Text="結果" Style="{DynamicResource CaptionTextStyle}" />
                        <TextBlock Grid.Column="4" Text="重要度" Style="{DynamicResource CaptionTextStyle}" />
                        <TextBlock Grid.Column="6" Text="Sheet" Style="{DynamicResource CaptionTextStyle}" />
                        <TextBlock Grid.Column="8" Text="Cell" Style="{DynamicResource CaptionTextStyle}" />
                        <TextBlock Grid.Column="10" Text="メッセージ" Style="{DynamicResource CaptionTextStyle}" />
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Results}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             SelectionMode="Single">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem"
                                   BasedOn="{StaticResource AppFlatSelectableRowListBoxItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcStep" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcStatus" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcSeverity" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcSheet" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="RcCell" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Step}" Style="{DynamicResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Status}" Style="{DynamicResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="4" Text="{Binding Severity}" Style="{DynamicResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="6" Text="{Binding SheetName}" Style="{DynamicResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="8" Text="{Binding CellRef}" Style="{DynamicResource BodyTextStyle}" />
                                        <TextBlock Grid.Column="10"
                                                   Text="{Binding Message}"
                                                   Style="{DynamicResource BodyTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
