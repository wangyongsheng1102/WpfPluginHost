<UserControl x:Class="Plugin.PostgreCompare.PostgreCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- タぶ項目のスタイルを定義 -->
            <Style x:Key="PostgreTabItemStyle" TargetType="TabItem">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource IndicatorBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource IndicatorBrush}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16" Background="Transparent">
        <!-- メインタブ -->
        <TabControl Background="Transparent" BorderThickness="0">
            <!-- DB 設定タブ -->
            <TabItem Header="📋 DB設定" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="データベース接続設定"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="4,0,0,12" />

                    <!-- 操作ボタン区域 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕ 接続を追加"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DbConfigViewModel.AddConnectionCommand}"
                                    Padding="16,6" />
                        </StackPanel>
                    </Border>

                    <!-- 接続一覧 -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="接続一覧"
                                       Style="{StaticResource SubtitleTextStyle}"
                                       Margin="0,0,0,12" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding DbConfigViewModel.Connections}">
                                    <ItemsControl.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="0,0,0,2"
                                                    Padding="0,8"
                                                    Margin="0,0,0,4">
                                                <Grid Margin="8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="1*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="設定名" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="1" Text="ホスト" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="2" Text="ポート" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="3" Text="データベース" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="4" Text="ユーザー" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="5" Text="パスワード" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="6" Text="WSL" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="7" Text="操作" Width="80" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.HeaderTemplate>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,6">
                                                <Grid Margin="8,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="1*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0" Text="{Binding ConfigurationName, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />
                                                    <TextBox Grid.Column="1" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />
                                                    <TextBox Grid.Column="2" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />
                                                    <TextBox Grid.Column="3" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />
                                                    
                                                    <ComboBox Grid.Column="4" IsEditable="True" Text="{Binding User, UpdateSourceTrigger=PropertyChanged}" Margin="4,2">
                                                        <ComboBoxItem Content="cisdb_unisys" />
                                                        <ComboBoxItem Content="orderdb_unisys" />
                                                        <ComboBoxItem Content="portaldb_unisys" />
                                                    </ComboBox>

                                                    <ComboBox Grid.Column="5" IsEditable="True" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="4,2">
                                                        <ComboBoxItem Content="cisdb_unisys" />
                                                        <ComboBoxItem Content="orderdb_unisys" />
                                                        <ComboBoxItem Content="portaldb_unisys" />
                                                    </ComboBox>

                                                    <ComboBox Grid.Column="6" ItemsSource="{Binding DataContext.DbConfigViewModel.WslDistributions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding WslDistro, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />

                                                    <Button Grid.Column="7" Content="🗑 削除" Width="80"
                                                            Style="{StaticResource ActionButtonStyle}"
                                                            Foreground="{DynamicResource ErrorBrush}"
                                                            Command="{Binding DataContext.DbConfigViewModel.RemoveConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" Margin="4,2" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- インポート・エクスポートタブ -->
            <TabItem Header="📤 インポート・エクスポート" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="データベースインポート・エクスポート"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="4,0,0,12" />

                    <!-- 接続選択 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="接続選択" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,8" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding ImportExportViewModel.Connections}"
                                          SelectedItem="{Binding ImportExportViewModel.SelectedConnection}"
                                          DisplayMemberPath="ConfigurationName" />
                                <Button Grid.Column="1"
                                        Content="📋 テーブルリストを読み込み"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding ImportExportViewModel.LoadTablesCommand}"
                                        Margin="12,0,0,0"
                                        Padding="16,6" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- テーブル一覧と操作 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="400" />
                        </Grid.ColumnDefinitions>

                        <!-- テーブル一覧 -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource CardElevatedBrush}"
                                CornerRadius="{StaticResource PanelRadius}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="テーブル一覧" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="✔ 全選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectAllTablesCommand}" Margin="0,0,8,0" />
                                    <Button Content="✖ 全解除" Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportExportViewModel.DeselectAllTablesCommand}" />
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="{Binding ImportExportViewModel.SelectedTableCount, StringFormat='選択中: {0} 件'}" Style="{StaticResource CaptionTextStyle}" Margin="0,0,0,8" />

                                <ListBox Grid.Row="3"
                                         ItemsSource="{Binding ImportExportViewModel.Tables}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" Text="{Binding SchemaName}" VerticalAlignment="Center" Style="{StaticResource CaptionTextStyle}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding TableName}" VerticalAlignment="Center" Style="{StaticResource BodyTextStyle}" />
                                                    <TextBlock Grid.Column="3" Text="{Binding RowCount, StringFormat='{}{0:N0} 行'}" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{StaticResource CaptionTextStyle}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- インポート・エクスポート操作 -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- エクスポート -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📤 エクスポート" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ImportExportViewModel.ExportFolderPath}" Tag="エクスポートフォルダを選択してください" />
                                        <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectExportFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Button Content="▶ エクスポート実行" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ImportExportViewModel.ExportTablesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>

                            <!-- インポート -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📥 インポート" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding ImportExportViewModel.ImportFolderPath}" Tag="インポートフォルダを選択してください" />
                                        <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectImportFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Button Content="▶ インポート実行" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ImportExportViewModel.ImportTablesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>

                            <!-- 进度条 -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Visibility="{Binding ImportExportViewModel.IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="処理中..." Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,8" />
                                    <ProgressBar Value="{Binding ImportExportViewModel.ProgressValue}" Maximum="100" Height="20" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- データ比較タブ -->
            <TabItem Header="🔍 データ比較" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="CSV ファイル比較"
                               Style="{StaticResource TitleTextStyle}"
                               Margin="4,0,0,12" />

                    <!-- 接続選択 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="接続選択" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="1"
                                      ItemsSource="{Binding CompareViewModel.Connections}"
                                      SelectedItem="{Binding CompareViewModel.SelectedConnection}"
                                      DisplayMemberPath="ConfigurationName" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="400" />
                        </Grid.ColumnDefinitions>

                        <!-- フォルダ選択 -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource CardElevatedBrush}"
                                CornerRadius="{StaticResource PanelRadius}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                Padding="12"
                                Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="フォルダ選択" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,16" />

                                <TextBlock Text="更新前フォルダ" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding CompareViewModel.BaseFolderPath}" />
                                    <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding CompareViewModel.SelectBaseFolderCommand}" Margin="8,0,0,0" />
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="旧フォルダ" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding CompareViewModel.OldFolderPath}" />
                                            <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding CompareViewModel.SelectOldFolderCommand}" Margin="8,0,0,0" />
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="新フォルダ" Style="{StaticResource BodyTextStyle}" Margin="0,0,0,8" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding CompareViewModel.NewFolderPath}" />
                                            <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding CompareViewModel.SelectNewFolderCommand}" Margin="8,0,0,0" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 导出设置和执行 -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="エクスポート設定" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding CompareViewModel.ExportFilePath}" />
                                        <Button Grid.Column="1" Content="📁 選択" Style="{StaticResource ActionButtonStyle}" Command="{Binding CompareViewModel.SelectExportFileCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                    
                                    <CheckBox Content="access_log.csv を含める"
                                              IsChecked="{Binding CompareViewModel.AccessLogChecked}"
                                              Margin="0,0,0,12" />
                                              
                                    <Button Content="▶ 比較実行" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CompareViewModel.CompareCsvFilesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="12"
                                    Visibility="{Binding CompareViewModel.IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="処理中..." Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,8" />
                                    <ProgressBar Value="{Binding CompareViewModel.ProgressValue}" Maximum="100" Height="20" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

