<UserControl x:Class="Plugin.PostgreCompare.PostgreCompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             mc:Ignorable="d"
             FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <!-- TabItem が Subtitle サイズのため内容が継承するのを防ぎ、本文サイズをボタンに明示 -->
            <Style x:Key="PostgrePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
            </Style>
            <Style x:Key="PostgreActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
            </Style>
            <!-- タぶ項目のスタイルを定義 -->
            <Style x:Key="PostgreTabItemStyle" TargetType="TabItem">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyBold}" />
                <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.SubtitleFontSize}" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,2"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource IndicatorBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource IndicatorBrush}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ButtonHoverGradientBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30" Background="Transparent">
        <!-- メインタブ -->
        <TabControl Background="Transparent" BorderThickness="0">
            <!-- DB 設定タブ -->
            <TabItem Header="DB設定" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 操作ボタン区域 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="接続を追加"
                                    Height="36"
                                    MinWidth="110"
                                    Padding="16,0"
                                    Style="{DynamicResource PostgrePrimaryButtonStyle}"
                                    Command="{Binding DbConfigViewModel.AddConnectionCommand}" />
                        </StackPanel>
                    </Border>

                    <!-- 接続一覧 -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="接続一覧"
                                       Style="{DynamicResource SubtitleTextStyle}"
                                       Margin="0,0,0,16" />

                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                
                                <!-- ヘッダー部分 -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,2"
                                        Padding="0,8"
                                        Margin="0,0,0,8">
                                    <Grid Margin="12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="設定名" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="1" Text="ホスト" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="2" Text="ポート" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="3" Text="データベース" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="4" Text="ユーザー" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="5" Text="パスワード" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                        <TextBlock Grid.Column="6" Text="操作" Width="80" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DbConfigViewModel.Connections}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,8">
                                                    <Grid Margin="12,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="1*" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="2*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding ConfigurationName, UpdateSourceTrigger=PropertyChanged}" />
                                                        </Border>
                                                        <Border Grid.Column="1" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                                                        </Border>
                                                        <Border Grid.Column="2" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                                                        </Border>
                                                        <Border Grid.Column="3" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" />
                                                        </Border>
                                                        
                                                        <Border Grid.Column="4" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}" IsEditable="True" Text="{Binding User, UpdateSourceTrigger=PropertyChanged}">
                                                                <ComboBoxItem Content="cisdb_unisys" />
                                                                <ComboBoxItem Content="orderdb_unisys" />
                                                                <ComboBoxItem Content="portaldb_unisys" />
                                                            </ComboBox>
                                                        </Border>

                                                        <Border Grid.Column="5" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="4,2">
                                                            <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}" IsEditable="True" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}">
                                                                <ComboBoxItem Content="cisdb_unisys" />
                                                                <ComboBoxItem Content="orderdb_unisys" />
                                                                <ComboBoxItem Content="portaldb_unisys" />
                                                            </ComboBox>
                                                        </Border>

                                                        <Button Grid.Column="6" Content="削除" Width="80" Height="36"
                                                                Style="{DynamicResource PostgreActionButtonStyle}"
                                                                Foreground="{DynamicResource ErrorBrush}"
                                                                Command="{Binding DataContext.DbConfigViewModel.RemoveConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}" Margin="4,2" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- インポート・エクスポートタブ -->
            <TabItem Header="インポート・エクスポート" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 接続選択 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="20"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="接続とスキーマの選択" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="0,0,8,0">
                                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                              ItemsSource="{Binding ImportExportViewModel.Connections}"
                                              SelectedItem="{Binding ImportExportViewModel.SelectedConnection}"
                                              DisplayMemberPath="ConfigurationName" />
                                </Border>
                                <Border Grid.Column="1" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Margin="0,0,12,0">
                                    <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                              ItemsSource="{Binding ImportExportViewModel.Schemas}"
                                              SelectedItem="{Binding ImportExportViewModel.SelectedSchema}" />
                                </Border>
                                <Button Grid.Column="2"
                                        Content="テーブルリストを読み込み"
                                        Height="36"
                                        Padding="16,0"
                                        Style="{DynamicResource PostgrePrimaryButtonStyle}"
                                        Command="{Binding ImportExportViewModel.LoadTablesCommand}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- テーブル一覧と操作：左は内容幅に追従、右は残り幅 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="320" />
                        </Grid.ColumnDefinitions>

                        <!-- テーブル一覧 -->
                        <Border Grid.Column="0"
                                HorizontalAlignment="Left"
                                MinWidth="0"
                                Background="{DynamicResource CardElevatedBrush}"
                                CornerRadius="{StaticResource PanelRadius}"
                                BorderBrush="{DynamicResource BorderSubtleBrush}"
                                BorderThickness="1"
                                Padding="20"
                                Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="テーブル一覧" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="全選択" Height="36" MinWidth="80" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectAllTablesCommand}" Margin="0,0,8,0" />
                                    <Button Content="全解除" Height="36" MinWidth="80" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding ImportExportViewModel.DeselectAllTablesCommand}" />
                                </StackPanel>

                                <TextBlock Grid.Row="2" Text="{Binding ImportExportViewModel.SelectedTableCount, StringFormat='選択中: {0} 件'}" Style="{DynamicResource CaptionTextStyle}" Margin="0,0,0,10" />

                                <Grid Grid.Row="3" Grid.IsSharedSizeScope="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- 列見出し（SharedSizeGroup で各行と列幅を共有） -->
                                    <Grid Grid.Row="0" Margin="8,0,8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblChk" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblSchema" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblName" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblRows" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="選択" Style="{DynamicResource CaptionTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="スキーマ" Style="{DynamicResource CaptionTextStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="4" Text="テーブル" Style="{DynamicResource CaptionTextStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="6" Text="行数" Style="{DynamicResource CaptionTextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                    </Grid>

                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding ImportExportViewModel.Tables}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             HorizontalAlignment="Left"
                                             HorizontalContentAlignment="Left"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource AppFlatSelectableRowListBoxItemStyle}">
                                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblChk" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblSchema" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblName" />
                                                            <ColumnDefinition Width="12" />
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="PgTblRows" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="{Binding SchemaName}" VerticalAlignment="Center" HorizontalAlignment="Center" Style="{DynamicResource CaptionTextStyle}" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding TableName}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Left"
                                                                   Margin="0"
                                                                   MaxWidth="520"
                                                                   Style="{DynamicResource BodyTextStyle}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="6" Text="{Binding RowCount, StringFormat='{}{0:N0} 行'}" VerticalAlignment="Center" HorizontalAlignment="Right" Style="{DynamicResource CaptionTextStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- インポート・エクスポート操作 -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- エクスポート -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="エクスポート「導出」" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding ImportExportViewModel.ExportFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectExportFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Button Content="エクスポート実行" Height="36" Style="{DynamicResource PostgrePrimaryButtonStyle}" Command="{Binding ImportExportViewModel.ExportTablesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>

                            <!-- インポート -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="インポート「導入」" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding ImportExportViewModel.ImportFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding ImportExportViewModel.SelectImportFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Button Content="インポート実行" Height="36" Style="{DynamicResource PostgrePrimaryButtonStyle}" Command="{Binding ImportExportViewModel.ImportTablesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- データ比較タブ -->
            <TabItem Header="比較" Style="{StaticResource PostgreTabItemStyle}">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 接続選択（上部固定、スクロール対象外） -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardElevatedBrush}"
                            CornerRadius="{StaticResource PanelRadius}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Padding="20"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="接続選択" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                            <Border Grid.Row="1" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36" Width="300" HorizontalAlignment="Left">
                                <ComboBox Style="{DynamicResource AppComboBoxFlatStyle}"
                                          ItemsSource="{Binding CompareViewModel.Connections}"
                                          SelectedItem="{Binding CompareViewModel.SelectedConnection}"
                                          DisplayMemberPath="ConfigurationName" />
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- フォルダ選択 -->
                            <Border Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="フォルダ選択" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,16" />

                                    <TextBlock Text="更新前フォルダ" Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding CompareViewModel.BaseFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding CompareViewModel.SelectBaseFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="旧フォルダ" Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding CompareViewModel.OldFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding CompareViewModel.SelectOldFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>

                                    <TextBlock Text="新フォルダ" Style="{DynamicResource BodyTextStyle}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding CompareViewModel.NewFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding CompareViewModel.SelectNewFolderCommand}" Margin="8,0,0,0" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- エクスポート設定 -->
                            <Border Background="{DynamicResource CardElevatedBrush}"
                                    CornerRadius="{StaticResource PanelRadius}"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    Padding="20"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="エクスポート設定" Style="{DynamicResource SubtitleTextStyle}" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Style="{DynamicResource AppInputChromeBorderStyle}" Height="36">
                                            <TextBox Style="{DynamicResource AppTextBoxFlatStyle}" Text="{Binding CompareViewModel.ExportFilePath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <Button Grid.Column="1" Content="選択" Height="36" MinWidth="70" Style="{DynamicResource PostgreActionButtonStyle}" Command="{Binding CompareViewModel.SelectExportFileCommand}" Margin="8,0,0,0" />
                                    </Grid>

                                    <CheckBox Content="access_log.csv を含める"
                                              IsChecked="{Binding CompareViewModel.AccessLogChecked}"
                                              Margin="0,0,0,16" />

                                    <Button Content="比較実行" Height="36" Style="{DynamicResource PostgrePrimaryButtonStyle}" Command="{Binding CompareViewModel.CompareCsvFilesCommand}" HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

