<Window x:Class="Plugin.PostgreCompare.Dialogs.WslDistroInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
        Title="WSL ディストリビューション"
        Width="360"
        SizeToContent="Height"
        MinWidth="320"
        MaxWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource ContentBackgroundBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="WslDialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="16,0" />
            </Style>
            <Style x:Key="WslDialogActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                <Setter Property="FontSize" Value="{x:Static abstractions:ThemeDimensions.BodyFontSize}" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Padding" Value="16,0" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource PanelRadius}"
                Padding="20"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Style="{StaticResource BodyTextStyle}"
                           TextWrapping="Wrap"
                           LineHeight="{x:Static abstractions:ThemeDimensions.LineHeightRelaxed}"
                           Text="PostgreSQL がインストールされている WSL のディストリビューション名を入力してください（例: Ubuntu-22.04）。pg ユーザーで source ~/.bash_profile の後に pg_ctl start を実行します。"
                           Margin="0,0,0,14" />

                <Border Grid.Row="1"
                        Style="{StaticResource AppInputChromeBorderStyle}"
                        Margin="0,0,0,16">
                    <TextBox x:Name="DistroTextBox"
                             Style="{StaticResource AppTextBoxFlatStyle}"
                             MinHeight="36"
                             VerticalContentAlignment="Center" />
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="オーケー"
                            MinWidth="88"
                            Style="{StaticResource WslDialogPrimaryButtonStyle}"
                            IsDefault="True"
                            Click="OkButton_Click" />
                    <Button Content="キャンセル"
                            MinWidth="100"
                            Margin="10,0,0,0"
                            Style="{StaticResource WslDialogActionButtonStyle}"
                            IsCancel="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
