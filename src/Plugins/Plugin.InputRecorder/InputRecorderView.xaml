<UserControl x:Class="Plugin.InputRecorder.InputRecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Options Bar -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="15"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderSubtleBrush}">
            <StackPanel>
                <TextBlock Text="マクロ録画オプション"
                           Margin="0,0,0,8"
                           Style="{StaticResource SubtitleTextStyle}"/>
                
                <TextBlock Text="録画ボタンを押すとメイン画面が最小化され、すべてのマウスとキーボード操作の記録を開始します。完了したらキーボードの [Esc] キーを押してください。"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Style="{StaticResource CaptionTextStyle}"
                           Opacity="0.86" />
                
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="● 録画開始" 
                            Style="{DynamicResource PrimaryButtonStyle}" 
                            Command="{Binding StartRecordingCommand}"
                            Visibility="{Binding IsRecording, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                            MinWidth="120" Height="36" Padding="16,0" />
                            
                    <Button Content="⏹ 停止" 
                            Style="{DynamicResource ActionButtonStyle}" 
                            Command="{Binding StopRecordingCommand}"
                            Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="#FFF87171"
                            Foreground="White"
                            MinWidth="120" Height="36" Padding="16,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Event List -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                CornerRadius="8"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Style>
            </Border.Style>
            <Grid>
                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="記録されたイベントがありません。" 
                               Style="{StaticResource SubtitleTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid ItemsSource="{Binding Events}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="All"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          VerticalGridLinesBrush="{DynamicResource BorderSubtleBrush}"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="40"
                          ColumnHeaderHeight="40"
                          FontFamily="{DynamicResource AppFontFamily}"
                          Foreground="{DynamicResource PrimaryTextBrush}"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource ContentBackgroundBrush}"
                          UseLayoutRounding="True"
                          ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="イベント" Binding="{Binding EventType}" Width="150" />
                        <DataGridTextColumn Header="時間 (ms)" Binding="{Binding TimeOffset}" Width="100" />
                        <DataGridTextColumn Header="X座標" Binding="{Binding X}" Width="80" />
                        <DataGridTextColumn Header="Y座標" Binding="{Binding Y}" Width="80" />
                        <DataGridTextColumn Header="キーコード" Binding="{Binding KeyCode}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="2" Padding="10,8"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Load/Save Script -->
                <Button Grid.Column="0" Content="📂 スクリプト読込..." 
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding LoadCommand}" />
                        
                <Button Grid.Column="1" Content="💾 スクリプト保存..."
                        MinWidth="120" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SaveCommand}" />

                <!-- Center: Status -->
                <TextBlock Grid.Column="2"
                           Margin="12,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Style="{StaticResource KeyInfoTextStyle}"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <!-- Right: Replay Action -->
                <Button Grid.Column="3" Content="▶ リプレイ実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ReplayCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
