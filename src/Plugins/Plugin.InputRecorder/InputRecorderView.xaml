<UserControl x:Class="Plugin.InputRecorder.InputRecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             FontSize="{x:Static abstractions:ThemeDimensions.BodyFontSize}"
             Background="{DynamicResource ContentBackgroundBrush}">
    <UserControl.Resources>
        <!-- 停止：Primary と同じテンプレートで Error を背景に（テーマの明暗に追従） -->
        <Style x:Key="InputRecorderStopButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- オプション（PixelCompare 上部カードと同系） -->
        <Border Grid.Row="0" Margin="0,0,0,24" Padding="20"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="{StaticResource PanelRadius}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderSubtleBrush}">
            <StackPanel>
                <TextBlock Text="マクロ録画オプション"
                           Margin="0,0,0,8"
                           Style="{DynamicResource SubtitleTextStyle}" />

                <TextBlock Text="録画ボタンを押すとメイン画面が最小化され、すべての操作の記録を開始します。完了したら [Esc] キーを押してください。録画中に [F9] キーを押すと全画面スクリーンショットを保存し、[F10] キーを押すと現在アクティブなウィンドウを自動スクロールしてフル画面長図をキャプチャします。"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Style="{DynamicResource BodyTextStyle}"
                           TextWrapping="Wrap" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="● 録画開始"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding StartRecordingCommand}"
                            MinWidth="120" Height="36" Padding="16,0" />

                    <Button Content="⏹ 停止"
                            Style="{StaticResource InputRecorderStopButtonStyle}"
                            Command="{Binding StopRecordingCommand}"
                            MinWidth="120" Height="36" Padding="16,0" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- イベント一覧：比較一覧と同じカード＋ListBox 行スタイル -->
        <Border Grid.Row="1" Margin="0,0,0,24" Padding="12,16"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="{StaticResource PanelRadius}"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderSubtleBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="イベント一覧"
                           Style="{DynamicResource SubtitleTextStyle}"
                           Margin="0,0,0,10" />

                <Grid Grid.Row="1" MinHeight="120">
                    <!-- 空状態 -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="記録されたイベントがありません。"
                                   Style="{DynamicResource BodyTextStyle}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <Grid Grid.IsSharedSizeScope="True">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="8,0,8,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrEvent" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrTime" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrX" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrY" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrKey" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="イベント" Style="{DynamicResource CaptionTextStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="時間 (ms)" Style="{DynamicResource CaptionTextStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="X座標" Style="{DynamicResource CaptionTextStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="6" Text="Y座標" Style="{DynamicResource CaptionTextStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="8" Text="キーコード" Style="{DynamicResource CaptionTextStyle}" VerticalAlignment="Center" />
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Events}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionMode="Single">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem"
                                       BasedOn="{StaticResource AppFlatSelectableRowListBoxItemStyle}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrEvent" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrTime" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrX" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrY" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="IrKey" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding EventType}"
                                                       VerticalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TimeOffset, StringFormat=\{0\} ms}"
                                                       VerticalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding X, StringFormat=X: \{0\}}"
                                                       VerticalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Column="6"
                                                       Text="{Binding Y, StringFormat=Y: \{0\}}"
                                                       VerticalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Column="8"
                                                       Text="{Binding KeyCode, StringFormat=Key: \{0\}}"
                                                       VerticalAlignment="Center"
                                                       Style="{DynamicResource BodyTextStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- アクションバー -->
        <Border Grid.Row="2" Padding="20,14"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource PanelRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="📂 スクリプト読み込み..."
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding LoadCommand}" />

                <Button Grid.Column="1"
                        Content="💾 スクリプト保存..."
                        MinWidth="120" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SaveCommand}" />

                <Button Grid.Column="3"
                        Content="▶ リプレイ実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ReplayCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
