<UserControl x:Class="Plugin.InputRecorder.InputRecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:abstractions="clr-namespace:Plugin.Abstractions;assembly=Plugin.Abstractions"
             Background="{DynamicResource ContentBackgroundBrush}">
    <Grid Margin="30"
          Background="{DynamicResource ContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Options Bar -->
        <Border Grid.Row="0" Margin="0,0,0,12" Padding="15"
                Background="{DynamicResource CardElevatedBrush}"
                CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource BorderSubtleBrush}">
            <StackPanel>
                <TextBlock Text="マクロ録画オプション"
                           Margin="0,0,0,8"
                           Style="{StaticResource SubtitleTextStyle}"/>
                
                <TextBlock Text="録画ボタンを押すとメイン画面が最小化され、すべてのマウスとキーボード操作の記録を開始します。完了したらキーボードの [Esc] キーを押してください。"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Style="{StaticResource CaptionTextStyle}"
                           Opacity="0.86" />
                
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="● 録画開始" 
                            Style="{DynamicResource PrimaryButtonStyle}" 
                            Command="{Binding StartRecordingCommand}"
                            MinWidth="120" Height="36" Padding="16,0" />
                            
                    <Button Content="⏹ 停止" 
                            Style="{DynamicResource ActionButtonStyle}" 
                            Command="{Binding StopRecordingCommand}"
                            Background="#FFF87171"
                            Foreground="White"
                            MinWidth="120" Height="36" Padding="16,0" Margin="12,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Event List -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                CornerRadius="8"
                SnapsToDevicePixels="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource CardElevatedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </Style>
            </Border.Style>
            <Grid>
                <!-- Empty State -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="記録されたイベントがありません。" 
                               Style="{StaticResource SubtitleTextStyle}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- ListBox for Events -->
                <ListBox ItemsSource="{Binding Events}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Style>
                        <Style TargetType="ListBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Events.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Style>
                    <!-- Header simulation -->
                    <ListBox.Template>
                        <ControlTemplate TargetType="ListBox">
                            <Border BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1" Padding="8,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="イベント" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="1" Text="時間 (ms)" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="2" Text="X座標" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="3" Text="Y座標" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Grid.Column="4" Text="キーコード" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" Focusable="false" Padding="{TemplateBinding Padding}">
                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ListBox.Template>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#143B82F6" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#0A3B82F6" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,10" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding EventType}" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding TimeOffset, StringFormat=\{0\} ms}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding X, StringFormat=X: \{0\}}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Y, StringFormat=Y: \{0\}}" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBlock Grid.Column="4" Text="{Binding KeyCode, StringFormat=Key: \{0\}}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Action Bar -->
        <Border Grid.Row="2" Padding="10,8"
                Background="{DynamicResource CardElevatedBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Load/Save Script -->
                <Button Grid.Column="0" Content="📂 スクリプト読込..." 
                        MinWidth="120" Height="36" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding LoadCommand}" />
                        
                <Button Grid.Column="1" Content="💾 スクリプト保存..."
                        MinWidth="120" Height="36" Margin="12,0,0,0" Padding="16,0"
                        Style="{DynamicResource ActionButtonStyle}"
                        Command="{Binding SaveCommand}" />

                <!-- Center: Status -->
                <TextBlock Grid.Column="2"
                           Margin="12,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                           Style="{StaticResource KeyInfoTextStyle}"
                           Text="{Binding StatusMessage}" TextWrapping="Wrap" />

                <!-- Right: Replay Action -->
                <Button Grid.Column="3" Content="▶ リプレイ実行"
                        MinWidth="160" Height="40" Padding="24,0"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding ReplayCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
